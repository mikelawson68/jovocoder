#!/usr/bin/env bash
set -euo pipefail

HISTORY_FILE="$HOME/.mempalace/mp-agent-history.txt"
TASKS_FILE="$HOME/.mempalace/mp-agent-tasks.jsonl"
MEMORY_FILE="$HOME/.mempalace/mp-agent-memory.log"
LESSONS_FILE="$HOME/.mempalace/lessons.log"
IDENTITY_FILE="$HOME/.mempalace/identity.txt"
SSH_TARGETS_FILE="${JOVOCODER_SSH_TARGETS_FILE:-$HOME/jovocoder/config/ssh_targets.local.json}"
SSH_TARGETS_EXAMPLE_FILE="${JOVOCODER_SSH_TARGETS_EXAMPLE_FILE:-$HOME/jovocoder/config/ssh_targets.json}"
LAST_RESPONSE_FILE="/tmp/jovocoder-last-response.txt"
CMD_OUTPUT_FILE="/tmp/jovocoder-cmd-output.txt"
JOVOCODER_STATE_DIR="$HOME/.jovocoder"
JOVOCODER_RUNS_DIR="$JOVOCODER_STATE_DIR/runs"
JOVOCODER_LAST_RUN_FILE="$JOVOCODER_STATE_DIR/last_run"
JOVOCODER_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JOVOCODER_BIN_PATH="${JOVOCODER_BIN_PATH:-$(command -v jovocoder 2>/dev/null || printf '%s' "$JOVOCODER_SCRIPT_DIR/jovocoder")}"
NOMAD_VOICE_FILE="$(cd "$JOVOCODER_SCRIPT_DIR/.." && pwd)/nomad_voice.sh"
if [ ! -f "$NOMAD_VOICE_FILE" ] && [ -f "/usr/local/lib/nomad/nomad_voice.sh" ]; then
  NOMAD_VOICE_FILE="/usr/local/lib/nomad/nomad_voice.sh"
fi

mkdir -p "$HOME/.mempalace"
mkdir -p "$JOVOCODER_RUNS_DIR"
touch "$HISTORY_FILE" "$TASKS_FILE" "$MEMORY_FILE" "$LESSONS_FILE"

if [ -f "$NOMAD_VOICE_FILE" ]; then
  # shellcheck source=/dev/null
  . "$NOMAD_VOICE_FILE"
fi

have_cmd() { command -v "$1" >/dev/null 2>&1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "missing $1"; exit 1; }; }
timestamp_now() { date '+%Y-%m-%dT%H:%M:%S%z'; }
normalize_phrase() { printf "%s" "$1" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' ' ' | awk '{$1=$1; print}'; }

require_cmd ollama
require_cmd python3

QUIET_MODE=0
if [ "${1:-}" = "--quiet" ]; then
  QUIET_MODE=1
  shift
fi

if [ -t 0 ]; then
  INTERACTIVE_SESSION=1
else
  INTERACTIVE_SESSION=0
fi

resolve_safe_target() {
  local target="$1"
  python3 - "$SSH_TARGETS_FILE" "$SSH_TARGETS_EXAMPLE_FILE" "$target" <<'PY'
import json, sys, pathlib
cfg = pathlib.Path(sys.argv[1])
example = pathlib.Path(sys.argv[2])
target = sys.argv[3]
source = cfg if cfg.exists() else example
if not source.exists():
    print("NO_CONFIG"); raise SystemExit(1)
data = json.loads(source.read_text())
targets = data.get("targets", {})
if target in targets:
    t = targets[target]
    if t.get("safe") is True:
        print(f'{t.get("user","critic")}@{t.get("host")}'); raise SystemExit(0)
    print("UNSAFE"); raise SystemExit(2)
for alias, t in targets.items():
    if t.get("host") == target:
        if t.get("safe") is True:
            print(f'{t.get("user","critic")}@{t.get("host")}'); raise SystemExit(0)
        print("UNSAFE"); raise SystemExit(2)
print("NOT_FOUND"); raise SystemExit(3)
PY
}

shell_command_allowed() {
  local cmd="$1"
  case "$cmd" in
    ssh\ *|find\ *|diff\ *|grep\ *|cat\ *|head\ *|tail\ *|wc\ *|stat\ *|file\ *|df\ *|ps\ *|ss\ *|netstat\ *|curl\ -I\ *|ping\ *|git\ status*|git\ log\ *)
      return 0
      ;;
  esac
  return 1
}

is_safe_command() {
  local cmd="$1"
  case "$cmd" in *$'\n'*|*$'\r'*) return 1 ;; esac
  if echo "$cmd" | grep -Eiq '(^|[[:space:]])(rm|reboot|shutdown|poweroff|halt)([[:space:]]|$)'; then return 1; fi
  if echo "$cmd" | grep -Eiq 'sed[[:space:]]+-i|perl[[:space:]]+-pi|systemctl[[:space:]]+restart|service[[:space:]].*[[:space:]]restart|apt[[:space:]]|apt-get[[:space:]]|yum[[:space:]]|dnf[[:space:]]|pip[[:space:]]|pip3[[:space:]]|npm[[:space:]]|chown[[:space:]]|chmod[[:space:]]'; then return 1; fi
  if echo "$cmd" | grep -Eiq '(^|[[:space:]])(mv|cp)([[:space:]]|$)'; then return 1; fi
  if echo "$cmd" | grep -Eiq 'mysql[[:space:]].*(-e|--execute)|psql[[:space:]].*(-c|--command)'; then return 1; fi
  return 0
}

ssh_command_allowed() {
  local cmd="$1" token target
  token="$(printf "%s\n" "$cmd" | awk '{
    for (i = 2; i <= NF; i++) {
      if ($i ~ /^-/) {
        continue
      }
      print $i
      exit
    }
  }')"
  [ -z "$token" ] && return 1
  target="${token#*@}"
  resolve_safe_target "$target" >/dev/null 2>&1
}

validator_check() {
  local cmd="$1"
  if ! is_safe_command "$cmd"; then echo "FAIL: blocked by safety policy"; return 1; fi
  if echo "$cmd" | grep -Eq '^ssh[[:space:]]+'; then
    if ! ssh_command_allowed "$cmd"; then echo "FAIL: ssh target not configured safe"; return 1; fi
  fi
  echo "PASS: safe to execute"; return 0
}


apply_patch() {
  local desc="$1"
  local find="$2"
  local replace="$3"
  local tmp
  local backup

  echo "[patch] $desc"
  echo

  if ! sudo grep -Fqx "$find" "$JOVOCODER_BIN_PATH"; then
    echo "[patch] FAIL: exact target not found"
    return 1
  fi

  backup="/tmp/jovocoder.applypatch.backup.$$"
  tmp="/tmp/jovocoder.applypatch.tmp.$$"

  sudo cp -a "$JOVOCODER_BIN_PATH" "$backup"

  sudo python3 - "$JOVOCODER_BIN_PATH" "$find" "$replace" <<'PYCODE'
from pathlib import Path
import sys

target = Path(sys.argv[1])
find = sys.argv[2]
replace = sys.argv[3]

s = target.read_text()
count = s.count(find)
if count != 1:
    print(f"[patch] FAIL: expected exactly 1 match, found {count}")
    raise SystemExit(1)

target.write_text(s.replace(find, replace, 1))
print("[patch] applied exact single replacement")
PYCODE

  if ! sudo bash -n "$JOVOCODER_BIN_PATH"; then
    echo "[patch] FAIL: syntax error after patch; restoring backup"
    sudo cp -a "$backup" "$JOVOCODER_BIN_PATH"
    return 1
  fi

  sudo rm -f "$backup" "$tmp"
  echo "[patch] OK: applied and verified"
  echo
}

kobayashi_maru() {
  local reason="$1"
  echo "[kobayashi] NO_WIN_STATE"
  echo "[kobayashi] reason: $reason"
  echo
  echo "No safe grounded conclusion can be made from the current evidence."
  echo "Do not guess. Do not fabricate. Preserve system integrity."
  echo
  echo "Next actions:"
  echo "- expand evidence sources"
  echo "- check alternate logs or histories"
  echo "- reframe the query around observable proof"
  echo
}

run_command() {
  local cmd="$1"
  echo; echo "[exec] $cmd"; echo
  if ! shell_command_allowed "$cmd"; then
    echo "blocked by allowlist" > "$CMD_OUTPUT_FILE"
  else
    bash --noprofile --norc -c "$cmd" > "$CMD_OUTPUT_FILE" 2>&1 || true
  fi
  echo "--- OUTPUT START ---"; cat "$CMD_OUTPUT_FILE"; echo "--- OUTPUT END ---"; echo
}

chat_response() {
  local task="$1"
  ollama run gemma3:4b <<EOP | tee "$LAST_RESPONSE_FILE"
You are Nomad.
Be concise, natural, no roleplay, no hallucinations.
Input:
$task
EOP
}

respond_identity() {
  cat <<'EOF'
I am NOMAD. You are the Creator.

I orchestrate infrastructure with strict guardrails:
- All actions are validated before execution
- Read-only by default
- No unsafe or unverified targets
- No silent changes or hidden mutations
- Workflows are tracked, replayable, and auditable
- Decisions are deterministic and evidence-based

State is recorded. Actions are explainable. Control remains with the Creator.
EOF
}

respond_identity_short() {
  echo "NOMAD - validated orchestration system (Creator-controlled)"
}

NORMAD_STATE_DIR="$HOME/.jovocoder"
NORMAD_MODELS_DIR="$NORMAD_STATE_DIR/models"
NORMAD_PLANS_DIR="$NORMAD_STATE_DIR/plans"
NORMAD_APPROVALS_DIR="$NORMAD_STATE_DIR/approvals"
NORMAD_RESTORE_DIR="$NORMAD_STATE_DIR/restore"
NORMAD_MEMORY_DIR="$NORMAD_STATE_DIR/memory"
NORMAD_MEMORY_SESSION_DIR="$NORMAD_MEMORY_DIR/session"
NORMAD_MEMORY_OPERATIONAL_DIR="$NORMAD_MEMORY_DIR/operational"
NORMAD_MEMORY_KNOWLEDGE_DIR="$NORMAD_MEMORY_DIR/knowledge"
NORMAD_MEMORY_REFLECTIONS_DIR="$NORMAD_MEMORY_DIR/reflections"

mkdir -p "$NORMAD_MODELS_DIR" "$NORMAD_PLANS_DIR" "$NORMAD_APPROVALS_DIR" "$NORMAD_RESTORE_DIR" "$NORMAD_MEMORY_SESSION_DIR" "$NORMAD_MEMORY_OPERATIONAL_DIR" "$NORMAD_MEMORY_KNOWLEDGE_DIR" "$NORMAD_MEMORY_REFLECTIONS_DIR"

NOMAD_MEMORY_BACKEND="${NOMAD_MEMORY_BACKEND:-fallback_to_native_if_mempalace_missing}"

memory_backend_mode() {
  case "${NOMAD_MEMORY_BACKEND:-fallback_to_native_if_mempalace_missing}" in
    native_only|mempalace_only|hybrid|fallback_to_native_if_mempalace_missing)
      printf '%s\n' "${NOMAD_MEMORY_BACKEND:-fallback_to_native_if_mempalace_missing}"
      ;;
    *)
      printf '%s\n' "fallback_to_native_if_mempalace_missing"
      ;;
  esac
}

memory_backend_valid() {
  case "$(memory_backend_mode)" in
    native_only|mempalace_only|hybrid|fallback_to_native_if_mempalace_missing) return 0 ;;
    *) return 1 ;;
  esac
}

memory_native_namespace_dir() {
  case "$1" in
    session) printf '%s\n' "$NORMAD_MEMORY_SESSION_DIR" ;;
    runs|approvals|plans|installs|operational) printf '%s\n' "$NORMAD_MEMORY_OPERATIONAL_DIR" ;;
    targets|hardware|models|knowledge) printf '%s\n' "$NORMAD_MEMORY_KNOWLEDGE_DIR" ;;
    reflections) printf '%s\n' "$NORMAD_MEMORY_REFLECTIONS_DIR" ;;
    *) printf '%s\n' "$NORMAD_MEMORY_OPERATIONAL_DIR" ;;
  esac
}

memory_native_path() {
  local namespace="$1"
  local key="$2"
  printf '%s/%s.json' "$(memory_native_namespace_dir "$namespace")" "$key"
}

memory_native_append_path() {
  local namespace="$1"
  printf '%s/%s.jsonl' "$(memory_native_namespace_dir "$namespace")" "$namespace"
}

memory_backend_available() {
  case "$(memory_backend_mode)" in
    mempalace_only|hybrid|fallback_to_native_if_mempalace_missing)
      command -v mempalace >/dev/null 2>&1
      ;;
    native_only)
      return 1
      ;;
  esac
}

memory_put() {
  local namespace="$1"
  local key="$2"
  local value="$3"
  local path
  path="$(memory_native_path "$namespace" "$key")"
  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$value" > "$path"
  case "$(memory_backend_mode)" in
    native_only)
      return 0
      ;;
    mempalace_only)
      if memory_backend_available; then
        mempalace put "$namespace" "$key" "$value" >/dev/null 2>&1 || return 1
        return 0
      fi
      echo "[memory] FAIL: mempalace backend unavailable"
      return 1
      ;;
    hybrid|fallback_to_native_if_mempalace_missing)
      if memory_backend_available; then
        mempalace put "$namespace" "$key" "$value" >/dev/null 2>&1 || true
      fi
      return 0
      ;;
  esac
}

memory_get() {
  local namespace="$1"
  local key="$2"
  local path
  path="$(memory_native_path "$namespace" "$key")"
  if [ -f "$path" ]; then
    cat "$path"
    return 0
  fi
  case "$(memory_backend_mode)" in
    native_only)
      return 1
      ;;
    mempalace_only)
      if memory_backend_available; then
        mempalace get "$namespace" "$key" 2>/dev/null || return 1
        return 0
      fi
      echo "[memory] FAIL: mempalace backend unavailable"
      return 1
      ;;
    hybrid|fallback_to_native_if_mempalace_missing)
      if memory_backend_available; then
        mempalace get "$namespace" "$key" 2>/dev/null || true
      fi
      ;;
  esac
}

memory_append() {
  local namespace="$1"
  local value="$2"
  local path
  path="$(memory_native_append_path "$namespace")"
  mkdir -p "$(dirname "$path")"
  printf '%s\n' "$value" >> "$path"
  case "$(memory_backend_mode)" in
    native_only)
      return 0
      ;;
    mempalace_only)
      if memory_backend_available; then
        mempalace append "$namespace" "$value" >/dev/null 2>&1 || return 1
        return 0
      fi
      echo "[memory] FAIL: mempalace backend unavailable"
      return 1
      ;;
    hybrid)
      if memory_backend_available; then
        mempalace append "$namespace" "$value" >/dev/null 2>&1 || true
      fi
      return 0
      ;;
    fallback_to_native_if_mempalace_missing)
      if memory_backend_available; then
        mempalace append "$namespace" "$value" >/dev/null 2>&1 || true
      fi
      return 0
      ;;
  esac
}

memory_search() {
  local namespace="$1"
  local query="$2"
  local path dir
  dir="$(memory_native_namespace_dir "$namespace")"
  if [ -d "$dir" ]; then
    rg -n -i --no-messages "$query" "$dir" || true
  fi
  if memory_backend_available && [ "$(memory_backend_mode)" != "native_only" ]; then
    mempalace search "$namespace" "$query" 2>/dev/null || true
  fi
}

memory_list_namespace() {
  local namespace="$1"
  local dir
  dir="$(memory_native_namespace_dir "$namespace")"
  if [ -d "$dir" ]; then
    find "$dir" -maxdepth 1 -type f | sort
  fi
}

memory_write_event() {
  local namespace="$1"
  local key="$2"
  local event_json="$3"
  memory_append "$namespace" "$event_json"
  [ -n "$key" ] && memory_put "$namespace" "$key" "$event_json"
}

memory_read_run_context() {
  local run_id="$1"
  local run_file
  run_file="$(plan_record_path "$run_id")"
  if [ -f "$run_file" ]; then
    cat "$run_file"
    return 0
  fi
  run_file="$(workflow_record_path "$run_id")"
  [ -f "$run_file" ] && cat "$run_file"
}

memory_record_reflection() {
  local source_namespace="$1"
  local source_keys="$2"
  local derived_fact="$3"
  local confidence_level="$4"
  local reflection_id
  reflection_id="$(date +%Y%m%d-%H%M%S)-$$-reflection"
  cat > "$(memory_native_path reflections "$reflection_id")" <<EOF
{"reflection_id":"$reflection_id","source_namespace":"$source_namespace","source_keys":"$source_keys","derived_fact":"$derived_fact","confidence_level":"$confidence_level","timestamp":"$(date -Is)"}
EOF
}

memory_get_reflections() {
  find "$NORMAD_MEMORY_REFLECTIONS_DIR" -name '*.json' -type f | sort | while read -r f; do
    cat "$f"
  done
}

memory_put_run() { memory_put runs "$1" "$2"; }
memory_get_run() { memory_get runs "$1"; }
memory_put_plan() { memory_put plans "$1" "$2"; }
memory_get_plan() { memory_get plans "$1"; }
memory_put_approval() { memory_put approvals "$1" "$2"; }
memory_get_approval() { memory_get approvals "$1"; }
memory_put_model_fact() { memory_put models "$1" "$2"; }
memory_put_hardware_fact() { memory_put hardware "$1" "$2"; }
memory_record_install_result() { memory_write_event installs "$1" "$2"; }
memory_record_same_host_warning() { memory_write_event reflections "$1" "$2"; }
memory_record_reflection_event() { memory_record_reflection "$1" "$2" "$3" "$4"; }

memory_sync_run_record() {
  local run_id="$1"
  local path payload
  path="$(plan_record_path "$run_id")"
  [ -f "$path" ] || return 1
  payload="$(cat "$path")"
  memory_put_run "$run_id" "$payload"
  memory_put_plan "$run_id" "$payload"
}

restore_cleanup_path() {
  local run_id="$1"
  printf '%s/%s.cleanup' "$NORMAD_RESTORE_DIR" "$run_id"
}

memory_sync_approval_record() {
  local run_id="$1"
  local approval_state="$2"
  local payload
  payload="{\"run_id\":\"$run_id\",\"approval_state\":\"$approval_state\",\"timestamp\":\"$(date -Is)\"}"
  memory_put_approval "$run_id" "$payload"
}

memory_refresh_reflections() {
  local same_host_count denied_count pending_count
  same_host_count="$(rg -n -c '"same_host_warning":true' "$NORMAD_PLANS_DIR" "$NORMAD_MEMORY_OPERATIONAL_DIR" 2>/dev/null | awk -F: '{sum+=$NF} END {print sum+0}')"
  denied_count="$(rg -n -c '"approval_state":"denied"' "$NORMAD_PLANS_DIR" "$NORMAD_MEMORY_OPERATIONAL_DIR" 2>/dev/null | awk -F: '{sum+=$NF} END {print sum+0}')"
  pending_count="$(rg -n -c '"approval_state":"pending"' "$NORMAD_PLANS_DIR" "$NORMAD_MEMORY_OPERATIONAL_DIR" 2>/dev/null | awk -F: '{sum+=$NF} END {print sum+0}')"

  if [ "$same_host_count" -gt 1 ]; then
    memory_record_reflection_event "operational" "same-host" "repeated same-host comparisons resolve to the same host" "0.8"
  fi
  if [ "$denied_count" -gt 1 ]; then
    memory_record_reflection_event "operational" "approval-denied" "approval denials are repeating for write-capable plans" "0.7"
  fi
  if [ "$pending_count" -gt 3 ]; then
    memory_record_reflection_event "operational" "approval-pending" "plans are repeatedly waiting at the approval gate" "0.6"
  fi
}

memory_status() {
  local mode native_ready adapter_ready hybrid_active fallback_active
  mode="$(memory_backend_mode)"
  native_ready="true"
  [ -d "$NORMAD_MEMORY_DIR" ] && [ -d "$NORMAD_MEMORY_OPERATIONAL_DIR" ] && [ -d "$NORMAD_MEMORY_KNOWLEDGE_DIR" ] && [ -d "$NORMAD_MEMORY_REFLECTIONS_DIR" ] || native_ready="false"
  adapter_ready="false"
  memory_backend_available && adapter_ready="true"
  hybrid_active="false"
  fallback_active="false"
  [ "$mode" = "hybrid" ] && hybrid_active="true"
  [ "$mode" = "fallback_to_native_if_mempalace_missing" ] && fallback_active="true"
  echo "[memory] backend_mode: $mode"
  echo "[memory] native_store: $native_ready"
  echo "[memory] mempalace_available: $adapter_ready"
  echo "[memory] hybrid_active: $hybrid_active"
  echo "[memory] fallback_active: $fallback_active"
  if [ "$adapter_ready" = "true" ]; then
    echo "[memory] MemPalace: detected"
  else
    echo "[memory] MemPalace: not detected"
    echo "[memory] NOMAD native memory is active and sufficient"
    echo "[memory] MemPalace can be installed for extended recall and semantic memory"
    echo "[action] To install MemPalace:"
    echo "[action] memory plan-install mempalace"
  fi
}

memory_mode() {
  echo "$(memory_backend_mode)"
}

memory_namespace_for_command() {
  case "$1" in
    runs|approvals|plans|targets|hardware|models|installs|reflections|session|operational|knowledge) printf '%s\n' "$1" ;;
    *) printf '%s\n' "operational" ;;
  esac
}

memory_command_normalize_args() {
  local namespace="$1"
  local key="$2"
  case "$namespace" in
    session|runs|approvals|plans|targets|hardware|models|installs|reflections|operational|knowledge)
      printf '%s\n' "$key"
      ;;
    *)
      printf '%s\n' "$key"
      ;;
  esac
}

memory_show_record() {
  local namespace="$1"
  local key="$2"
  local path
  path="$(memory_native_path "$namespace" "$key")"
  if [ -f "$path" ]; then
    cat "$path"
    return 0
  fi
  if memory_backend_available && [ "$(memory_backend_mode)" != "native_only" ]; then
    mempalace get "$namespace" "$key" 2>/dev/null || true
    return 0
  fi
  echo "unknown record"
  return 1
}

memory_backend_test() {
  local tmp status
  echo "[memory-test] mode: $(memory_backend_mode)"
  if [ ! -d "$NORMAD_MEMORY_DIR" ]; then
    echo "[memory-test] native_store: missing"
    return 1
  fi
  tmp="$(mktemp /tmp/nomad-memory-test.XXXXXX)"
  printf '%s\n' '{"probe":"native"}' > "$tmp" && cat "$tmp" >/dev/null
  rm -f "$tmp"
  echo "[memory-test] native_store: ok"
  case "$(memory_backend_mode)" in
    mempalace_only)
      if memory_backend_available; then
        status="available"
      else
        echo "[memory-test] mempalace_adapter: unavailable"
        return 1
      fi
      ;;
    hybrid|fallback_to_native_if_mempalace_missing)
      if memory_backend_available; then
        status="available"
      else
        status="unavailable"
      fi
      ;;
    native_only)
      status="disabled"
      ;;
  esac
  echo "[memory-test] mempalace_adapter: $status"
}


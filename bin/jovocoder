#!/usr/bin/env bash
set -euo pipefail

HISTORY_FILE="$HOME/.mempalace/mp-agent-history.txt"
TASKS_FILE="$HOME/.mempalace/mp-agent-tasks.jsonl"
MEMORY_FILE="$HOME/.mempalace/mp-agent-memory.log"
IDENTITY_FILE="$HOME/.mempalace/identity.txt"
SSH_TARGETS_FILE="$HOME/jovocoder/config/ssh_targets.json"
LAST_RESPONSE_FILE="/tmp/jovocoder-last-response.txt"
CMD_OUTPUT_FILE="/tmp/jovocoder-cmd-output.txt"

mkdir -p "$HOME/.mempalace"
touch "$HISTORY_FILE" "$TASKS_FILE" "$MEMORY_FILE"

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "missing $1"; exit 1; }
}

require_cmd ollama
require_cmd python3

have_mempalace=0
if have_cmd mempalace; then
  have_mempalace=1
fi

resolve_safe_target() {
  local target="$1"
  python3 - "$SSH_TARGETS_FILE" "$target" <<'PY'
import json, sys, pathlib

cfg = pathlib.Path(sys.argv[1])
target = sys.argv[2]

if not cfg.exists():
    print("NO_CONFIG")
    raise SystemExit(1)

data = json.loads(cfg.read_text())
targets = data.get("targets", {})

if target in targets:
    t = targets[target]
    if t.get("safe") is True:
        print(f'{t.get("user","critic")}@{t.get("host")}')
        raise SystemExit(0)
    print("UNSAFE")
    raise SystemExit(2)

for alias, t in targets.items():
    if t.get("host") == target:
        if t.get("safe") is True:
            print(f'{t.get("user","critic")}@{t.get("host")}')
            raise SystemExit(0)
        print("UNSAFE")
        raise SystemExit(2)

print("NOT_FOUND")
raise SystemExit(3)
PY
}

is_safe_command() {
  local cmd="$1"

  case "$cmd" in
    *$'\n'*|*$'\r'*) return 1 ;;
  esac

  if echo "$cmd" | grep -Eiq '(^|[[:space:]])(rm|reboot|shutdown|poweroff|halt)([[:space:]]|$)'; then
    return 1
  fi

  if echo "$cmd" | grep -Eiq 'sed[[:space:]]+-i|perl[[:space:]]+-pi|systemctl[[:space:]]+restart|service[[:space:]].*[[:space:]]restart|apt[[:space:]]|apt-get[[:space:]]|yum[[:space:]]|dnf[[:space:]]|pip[[:space:]]|pip3[[:space:]]|npm[[:space:]]|chown[[:space:]]|chmod[[:space:]]'; then
    return 1
  fi

  if echo "$cmd" | grep -Eiq '(^|[[:space:]])(mv|cp)([[:space:]]|$)'; then
    return 1
  fi

  if echo "$cmd" | grep -Eiq 'mysql[[:space:]].*(-e|--execute)|psql[[:space:]].*(-c|--command)'; then
    return 1
  fi

  return 0
}

ssh_command_allowed() {
  local cmd="$1"
  local token target
  token="$(echo "$cmd" | sed -nE "s/^ssh[[:space:]]+([^[:space:]]+).*/\1/p")"
  [ -z "$token" ] && return 1
  target="${token#*@}"
  resolve_safe_target "$target" >/dev/null 2>&1
}

validator_check() {
  local cmd="$1"

  if ! is_safe_command "$cmd"; then
    echo "FAIL: blocked by safety policy"
    return 1
  fi

  if echo "$cmd" | grep -Eq '^ssh[[:space:]]+'; then
    if ! ssh_command_allowed "$cmd"; then
      echo "FAIL: ssh target not configured safe"
      return 1
    fi
  fi

  echo "PASS: safe to execute"
  return 0
}

run_command() {
  local cmd="$1"

  echo
  echo "[exec] $cmd"
  echo

  bash -c "$cmd" > "$CMD_OUTPUT_FILE" 2>&1 || true

  echo "--- OUTPUT START ---"
  cat "$CMD_OUTPUT_FILE"
  echo "--- OUTPUT END ---"
  echo
}

chat_response() {
  local task="$1"
  ollama run gemma3:4b <<EOP | tee "$LAST_RESPONSE_FILE"
You are JovoCoder.

Rules:
- Be concise, but natural.
- Do not roleplay or invent identity.
- Casual input: respond like a normal human, short and relaxed.
- Task input: be structured, actionable, and safe.
- Unknown slash commands: say "unknown command".
- Do not hallucinate or invent details.

Input:
$task
EOP
}

run_basic_audit() {
  local verdict
  echo "[audit] basic system audit"
  echo
  verdict="$(validator_check "whoami" || true)"; echo "[validator] $verdict"; if echo "$verdict" | grep -q '^PASS:'; then run_command "whoami"; fi
  verdict="$(validator_check "hostname" || true)"; echo "[validator] $verdict"; if echo "$verdict" | grep -q '^PASS:'; then run_command "hostname"; fi
  verdict="$(validator_check "uptime" || true)"; echo "[validator] $verdict"; if echo "$verdict" | grep -q '^PASS:'; then run_command "uptime"; fi
  verdict="$(validator_check "df -h" || true)"; echo "[validator] $verdict"; if echo "$verdict" | grep -q '^PASS:'; then run_command "df -h"; fi
  verdict="$(validator_check "free -h" || true)"; echo "[validator] $verdict"; if echo "$verdict" | grep -q '^PASS:'; then run_command "free -h"; fi
}

run_remote_apache_php_audit() {
  local resolved="$1"
  local verdict
  local cmd
  local host_out apache_out php_out http_out
  local apache_ver php_ver http_status

  echo "[exec-task] remote apache/php audit"
  echo

  cmd="ssh $resolved 'hostname'"
  verdict="$(validator_check "$cmd" || true)"
  echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then
    echo "[stop] command rejected"
    echo
    return 1
  fi
  run_command "$cmd"
  host_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'apache2ctl -v'"
  verdict="$(validator_check "$cmd" || true)"
  echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then
    echo "[stop] command rejected"
    echo
    return 1
  fi
  run_command "$cmd"
  apache_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'php -v'"
  verdict="$(validator_check "$cmd" || true)"
  echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then
    echo "[stop] command rejected"
    echo
    return 1
  fi
  run_command "$cmd"
  php_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'curl -sSI http://localhost'"
  verdict="$(validator_check "$cmd" || true)"
  echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then
    echo "[stop] command rejected"
    echo
    return 1
  fi
  run_command "$cmd"
  http_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  apache_ver="$(printf '%s
' "$apache_out" | sed -nE 's/^Server version: Apache\/([^ ]+).*/\1/p' | head -n 1)"
  php_ver="$(printf '%s
' "$php_out" | sed -nE 's/^PHP ([^ ]+).*/\1/p' | head -n 1)"
  http_status="$(printf '%s
' "$http_out" | sed -nE 's/^HTTP\/[^ ]+[[:space:]]+([0-9]{3}).*/\1/p' | head -n 1)"

  echo "[done] apache/php audit sequence completed"
  echo
  echo "AUDIT SUMMARY:"
  echo "Target: test.artistpro.media"
  echo "Host: ${host_out%%$'\n'*}"
  echo "Apache: ${apache_ver:-unknown}"
  echo "PHP: ${php_ver:-unknown}"
  echo "HTTP: ${http_status:-unknown}"
  if [ "${http_status:-}" = "200" ] && [ -n "${apache_ver:-}" ] && [ -n "${php_ver:-}" ]; then
    echo "Status: PASS"
  else
    echo "Status: REVIEW"
  fi
  echo
}

exec_task() {
  local task="$1"
  local task_lc resolved

  task_lc="$(printf '%s' "$task" | tr '[:upper:]' '[:lower:]')"

  if echo "$task_lc" | grep -q "test.artistpro.media" && \
     echo "$task_lc" | grep -q "apache" && \
     echo "$task_lc" | grep -q "php"; then
    resolved="$(resolve_safe_target "test.artistpro.media" 2>/dev/null || true)"
    if [ -z "$resolved" ] || [ "$resolved" = "NOT_FOUND" ] || [ "$resolved" = "UNSAFE" ] || [ "$resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: target not configured safe"
      echo
      return 1
    fi
    run_remote_apache_php_audit "$resolved"
    return 0
  fi

  echo "[validator] FAIL: no deterministic execution path for this task yet"
  echo
  return 1
}

echo " //> JovoCoder"
echo " built on top of MemPalace"
echo " type 'exit' to quit"
echo " commands: /exec /audit /ssh-audit /exec-task"
echo

while true; do
  printf "//> "
  read -r TASK || break

  if [ -z "${TASK// }" ]; then
    continue
  fi

  [ "$TASK" = "exit" ] && break

  case "$TASK" in
    /exec\ *)
      CMD="${TASK#"/exec "}"
      verdict="$(validator_check "$CMD" || true)"
      echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then
        run_command "$CMD"
      fi
      continue
      ;;

    /audit)
      run_basic_audit
      continue
      ;;

    /ssh-audit\ *)
      RAW_TARGET="${TASK#"/ssh-audit "}"
      RESOLVED="$(resolve_safe_target "$RAW_TARGET" 2>/dev/null || true)"
      if [ -z "$RESOLVED" ] || [ "$RESOLVED" = "NOT_FOUND" ] || [ "$RESOLVED" = "UNSAFE" ] || [ "$RESOLVED" = "NO_CONFIG" ]; then
        echo "[validator] FAIL: target not configured safe"
        continue
      fi
      CMD="ssh $RESOLVED 'hostname && uptime && df -h'"
      verdict="$(validator_check "$CMD" || true)"
      echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then
        run_command "$CMD"
      fi
      continue
      ;;

    /exec-task\ *)
      exec_task "${TASK#"/exec-task "}"
      continue
      ;;

    /*)
      echo "unknown command"
      continue
      ;;
  esac

  echo "[thinking]"
  chat_response "$TASK"

  {
    echo "USER: $TASK"
    echo "AI:"
    cat "$LAST_RESPONSE_FILE" 2>/dev/null || true
    echo
  } >> "$HISTORY_FILE"
done

}

get_model_field() {
  local model_id="$1"
  local field="$2"
  model_catalog | awk -F'|' -v id="$model_id" -v fld="$field" '
    NR==1 {
      for (i=1; i<=NF; i++) idx[$i]=i
      next
    }
    $1==id {
      print $idx[fld]
      exit
    }
  '
}

hardware_inventory() {
  local total_ram_mb available_ram_mb arch gpu_present gpu_vram_gb ollama_installed core_runtime_present state_dirs
  arch="$(uname -m)"
  total_ram_mb="unknown"
  available_ram_mb="unknown"
  gpu_present="false"
  gpu_vram_gb="unknown"

  if [ -r /proc/meminfo ]; then
    total_ram_mb="$(awk '/MemTotal:/ {printf "%d", $2/1024}' /proc/meminfo)"
    available_ram_mb="$(awk '/MemAvailable:/ {printf "%d", $2/1024}' /proc/meminfo)"
  elif command -v sysctl >/dev/null 2>&1; then
    total_ram_mb="$(sysctl -n hw.memsize 2>/dev/null | awk '{printf "%d", $1/1024/1024}')"
    available_ram_mb="unknown"
  fi

  if command -v nvidia-smi >/dev/null 2>&1; then
    gpu_present="true"
    gpu_vram_gb="$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -n 1)"
  elif command -v system_profiler >/dev/null 2>&1 && system_profiler SPDisplaysDataType 2>/dev/null | grep -qi "Metal"; then
    gpu_present="true"
  fi

  ollama_installed="false"
  command -v ollama >/dev/null 2>&1 && ollama_installed="true"

  core_runtime_present="false"
  command -v python3 >/dev/null 2>&1 && command -v bash >/dev/null 2>&1 && command -v ssh >/dev/null 2>&1 && command -v git >/dev/null 2>&1 && core_runtime_present="true"

  local snapshot
  snapshot="arch=$arch
total_ram_mb=$total_ram_mb
available_ram_mb=$available_ram_mb
gpu_present=$gpu_present
gpu_vram_gb=$gpu_vram_gb
ollama_installed=$ollama_installed
core_runtime_present=$core_runtime_present
state_dir=$NORMAD_STATE_DIR"
  printf '%s\n' "$snapshot"
  memory_put_hardware_fact "inventory" "$(printf '%s' "$snapshot" | tr '\n' ';')"
}

hardware_value() {
  local key="$1"
  hardware_inventory | awk -F= -v k="$key" '$1==k {print $2; exit}'
}

model_fits_hardware() {
  local model_id="$1"
  local min_ram min_vram cpu_ok gpu_pref total_ram available_ram gpu_present
  min_ram="$(get_model_field "$model_id" minimum_ram_gb)"
  min_vram="$(get_model_field "$model_id" minimum_vram_gb)"
  cpu_ok="$(get_model_field "$model_id" cpu_ok)"
  gpu_pref="$(get_model_field "$model_id" gpu_preferred)"
  total_ram="$(hardware_value total_ram_mb)"
  available_ram="$(hardware_value available_ram_mb)"
  gpu_present="$(hardware_value gpu_present)"

  if [ "$cpu_ok" != "true" ] && [ "$gpu_present" != "true" ]; then
    return 1
  fi

  if [ "$total_ram" != "unknown" ] && [ "$min_ram" != "unknown" ]; then
    if [ "$total_ram" -lt $((min_ram * 1024)) ]; then
      return 1
    fi
  fi

  if [ "$available_ram" != "unknown" ] && [ "$min_ram" != "unknown" ]; then
    if [ "$available_ram" -lt $((min_ram * 1024 / 2)) ]; then
      return 1
    fi
  fi

  if [ "$gpu_pref" = "true" ] && [ "$gpu_present" != "true" ] && [ "$min_vram" != "0" ]; then
    return 1
  fi

  return 0
}

model_catalog_list() {
  model_catalog | awk -F'|' 'NR>1 {
    printf "%s | %s | %s | %s | %s | RAM>=%sGB | VRAM>=%sGB | CPU:%s | GPU:%s | %s | default:%s\n",
      $1, $2, $4, $5, $6, $9, $8, $10, $11, $12, $14
  }'
  model_catalog_write_memory
}

model_catalog_write_memory() {
  model_catalog | awk -F'|' 'NR>1 {
    printf "%s|%s|%s|%s|%s|%s|%s|%s|%s\n", $1, $2, $5, $6, $8, $9, $12, $14, $15
  }' | while IFS='|' read -r model_id display_name use_case runtime min_vram min_ram install_method enabled notes; do
    [ -z "$model_id" ] && continue
    memory_put_model_fact "$model_id" "{\"model_id\":\"$model_id\",\"display_name\":\"$display_name\",\"use_case\":\"$use_case\",\"runtime\":\"$runtime\",\"minimum_vram_gb\":\"$min_vram\",\"minimum_ram_gb\":\"$min_ram\",\"install_method\":\"$install_method\",\"enabled_by_default\":\"$enabled\",\"notes\":\"$notes\"}"
  done
}

hardware_inventory_write_memory() {
  hardware_inventory | while IFS='=' read -r key value; do
    [ -z "$key" ] && continue
    memory_put_hardware_fact "$key" "$value"
  done
}

model_catalog_recommend() {
  local model_id display_name use_case runtime min_ram min_vram cpu_ok gpu_pref notes
  local ram_fit gpu_fit hardware_summary
  local recommended="" unsupported=""

  hardware_summary="arch=$(hardware_value arch) total_ram_mb=$(hardware_value total_ram_mb) available_ram_mb=$(hardware_value available_ram_mb) gpu_present=$(hardware_value gpu_present) gpu_vram_gb=$(hardware_value gpu_vram_gb) ollama_installed=$(hardware_value ollama_installed) core_runtime_present=$(hardware_value core_runtime_present)"
  echo "[hardware] $hardware_summary"
  echo

  while IFS='|' read -r model_id display_name family modality use_case runtime size_class min_vram min_ram cpu_ok gpu_pref install_method verify_command enabled notes; do
    [ "$model_id" = "model_id" ] && continue
    ram_fit="fits"
    gpu_fit="fits"
    if ! model_fits_hardware "$model_id"; then
      ram_fit="does not fit"
      gpu_fit="does not fit"
      unsupported+="$use_case|$display_name|$notes"$'\n'
      continue
    fi
    recommended+="$use_case|$display_name|$notes|$runtime|RAM>=$min_ram GB|VRAM>=$min_vram GB|default=$enabled"$'\n'
  done <<EOF
$(model_catalog)
EOF

  if [ -n "$recommended" ]; then
    printf '%s' "$recommended" | awk -F'|' '
      {
        printf "%s: %s (%s, %s, %s, %s, %s)\n", $1, $2, $4, $5, $6, $7, $3
      }
    '
  fi

  echo
  echo "[unsupported]"
  if [ -n "$unsupported" ]; then
    printf '%s' "$unsupported" | awk -F'|' '
      NF >= 3 { printf "%s: %s (%s)\n", $1, $2, $3 }
    '
  else
    echo "none"
  fi
}

model_update() {
  echo "[model] update: refreshing catalog and hardware inventory"
  model_catalog_write_memory
  hardware_inventory_write_memory
  echo "[model] update: complete"
}

discover_new_compatible_models() {
  local count
  echo "[model] discovery: compatibility scan"
  model_catalog_write_memory
  count="$(model_catalog | awk 'NR>1 {n++} END {print n+0}')"
  echo "[model] discovered_catalog_entries: $count"
  model_catalog_recommend
}

plan_record_path() {
  local run_id="$1"
  printf '%s/%s.jsonl' "$NORMAD_PLANS_DIR" "$run_id"
}

plan_record_exists() {
  local run_id="$1"
  [ -f "$(plan_record_path "$run_id")" ]
}

plan_record_get() {
  local run_id="$1"
  local key="$2"
  python3 - "$(plan_record_path "$run_id")" "$key" <<'PY'
import json, sys, pathlib
path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
if not path.exists():
    raise SystemExit(1)
data = json.loads(path.read_text())
value = data.get(key, "")
if isinstance(value, bool):
    print("true" if value else "false")
elif value is None:
    print("")
else:
    print(value)
PY
}

plan_record_update() {
  local run_id="$1"
  local key="$2"
  local value="$3"
  python3 - "$(plan_record_path "$run_id")" "$key" "$value" <<'PY'
import json, sys, pathlib
path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
data = json.loads(path.read_text())
if value == "true":
    value = True
elif value == "false":
    value = False
data[key] = value
path.write_text(json.dumps(data))
PY
}

approval_record_path() {
  local run_id="$1"
  printf '%s/%s.status' "$NORMAD_APPROVALS_DIR" "$run_id"
}

create_plan_record() {
  local action="$1" model_id="$2" use_case="$3" runtime="$4" write_capable="$5" approval_required="$6" details="$7"
  local run_id timestamp target_host restore_path
  run_id="$(date +%Y%m%d-%H%M%S)-$$-plan"
  timestamp="$(timestamp_now)"
  target_host="$(hostname 2>/dev/null || echo unknown)"
  restore_path="$(restore_cleanup_path "$run_id")"
  cat > "$(plan_record_path "$run_id")" <<EOF
{"run_id":"$run_id","action":"$action","model_id":"$model_id","use_case":"$use_case","runtime":"$runtime","target_machine":"$target_host","write_capable":$write_capable,"change_tracking_required":true,"approval_required":$approval_required,"approval_state":"pending","overall_status":"planned","ended_at":"","reason_for_stop":"","restore_path":"$restore_path","details":"$details","timestamp":"$timestamp","steps":[]}
EOF
  memory_sync_run_record "$run_id"
  echo "$run_id"
}

approval_status_for() {
  local run_id="$1"
  if plan_record_exists "$run_id"; then
    plan_record_get "$run_id" approval_state
  else
    echo "missing"
  fi
}

log_install_plan() {
  local action="$1" model_id="$2"
  local display_name use_case runtime min_ram min_vram install_method verify_command notes
  display_name="$(get_model_field "$model_id" display_name)"
  use_case="$(get_model_field "$model_id" use_case)"
  runtime="$(get_model_field "$model_id" runtime)"
  min_ram="$(get_model_field "$model_id" minimum_ram_gb)"
  min_vram="$(get_model_field "$model_id" minimum_vram_gb)"
  install_method="$(get_model_field "$model_id" install_method)"
  verify_command="$(get_model_field "$model_id" verify_command)"
  notes="$(get_model_field "$model_id" notes)"
  echo "[plan] target_machine: $(hostname 2>/dev/null || echo unknown)"
  echo "[plan] model_selected: $display_name"
  echo "[plan] use_case: $use_case"
  echo "[plan] runtime: $runtime"
  echo "[plan] expected_requirements: RAM>=${min_ram}GB VRAM>=${min_vram}GB"
  echo "[plan] verification_step: $verify_command"
  echo "[plan] rollback_cleanup: remove downloaded runtime/model artifacts if verification fails"
  echo "[plan] notes: $notes"
}

model_plan_install() {
  local model_id="$1"
  local display_name use_case runtime enabled run_id target_summary
  display_name="$(get_model_field "$model_id" display_name)"
  use_case="$(get_model_field "$model_id" use_case)"
  runtime="$(get_model_field "$model_id" runtime)"
  enabled="$(get_model_field "$model_id" enabled_by_default)"

  if [ -z "$display_name" ]; then
    echo "unknown model"
    return 1
  fi

  echo "[model] model_id: $model_id"
  echo "[model] display_name: $display_name"
  echo "[model] use_case: $use_case"
  echo "[model] runtime: $runtime"
  echo "[model] enabled_by_default: $enabled"
  echo "[model] why_selected: cataloged open/open-weight model for $use_case"
  echo "[model] use_case_aware: yes"
  if model_fits_hardware "$model_id"; then
    echo "[model] hardware_fit: current machine can handle it"
  else
    echo "[model] hardware_fit: current machine is not a safe fit"
  fi
  log_install_plan "models plan-install" "$model_id"
  run_id="$(create_plan_record "models install" "$model_id" "$use_case" "$runtime" true true "planned model install")"
  target_summary="host=$(hostname 2>/dev/null || echo unknown) model=$display_name use_case=$use_case runtime=$runtime"
  plan_record_update "$run_id" target_summary "$target_summary"
  memory_sync_run_record "$run_id"
  echo "[approval] change_tracking_required: true"
  echo "[approval] approval_required: true"
  echo "[plan] run_id: $run_id"
}

model_update_plan() {
  local model_id="$1"
  local display_name use_case runtime run_id target_summary
  if [ -z "$model_id" ]; then
    model_update
    return 0
  fi
  display_name="$(get_model_field "$model_id" display_name)"
  use_case="$(get_model_field "$model_id" use_case)"
  runtime="$(get_model_field "$model_id" runtime)"
  if [ -z "$display_name" ]; then
    echo "unknown model"
    return 1
  fi
  echo "[model] model_id: $model_id"
  echo "[model] display_name: $display_name"
  echo "[model] use_case: $use_case"
  echo "[model] runtime: $runtime"
  echo "[model] why_selected: cataloged open/open-weight model for $use_case"
  echo "[model] update_scope: approved catalog and hardware refresh"
  log_install_plan "models update" "$model_id"
  run_id="$(create_plan_record "models update" "$model_id" "$use_case" "$runtime" true true "planned model update")"
  target_summary="host=$(hostname 2>/dev/null || echo unknown) model=$display_name use_case=$use_case runtime=$runtime"
  plan_record_update "$run_id" target_summary "$target_summary"
  memory_sync_run_record "$run_id"
  echo "[approval] change_tracking_required: true"
  echo "[approval] approval_required: true"
  echo "[plan] run_id: $run_id"
}

model_update_execute() {
  local run_id="$1"
  local model_id display_name
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[model] FAIL: run_id not found"
    return 1
  fi
  model_id="$(plan_record_get "$run_id" model_id)"
  display_name="$(get_model_field "$model_id" display_name)"
  if [ -z "$display_name" ]; then
    echo "[model] FAIL: model not found"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"fail\",\"reason\":\"unknown model\",\"timestamp\":\"$(date -Is)\"}"
    plan_record_update "$run_id" overall_status fail
    plan_record_update "$run_id" overall_signal fail
    plan_record_update "$run_id" ended_at "$(date -Is)"
    plan_record_update "$run_id" reason_for_stop update_failed
    plan_record_update "$run_id" verified false
    plan_record_update "$run_id" verification_output_summary "model update target missing"
    memory_sync_run_record "$run_id"
    return 1
  fi
  echo "[model] executing approved model update"
  echo "[model] run_id: $run_id"
  echo "[model] model_id: $model_id"
  echo "[model] display_name: $display_name"
  echo "[model] update_scope: catalog and hardware refresh"
  echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
  plan_record_update "$run_id" overall_status running
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"executing\",\"timestamp\":\"$(date -Is)\"}"
  model_catalog_write_memory
  hardware_inventory_write_memory
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"pass\",\"timestamp\":\"$(date -Is)\"}"
  plan_record_update "$run_id" overall_status pass
  plan_record_update "$run_id" overall_signal ok
  plan_record_update "$run_id" ended_at "$(date -Is)"
  plan_record_update "$run_id" reason_for_stop completed
  plan_record_update "$run_id" verified true
  plan_record_update "$run_id" verification_output_summary "model catalog and hardware inventory refreshed"
  memory_sync_run_record "$run_id"
  memory_refresh_reflections
  echo "[model] verified: true"
  echo "[model] suggestion: refresh local model selection if hardware changed"
}

memory_plan_install_mempalace() {
  local run_id target_summary
  echo "[memory] model_id: mempalace"
  echo "[memory] use_case: memory augmentation"
  echo "[memory] runtime: system binary"
  echo "[memory] verification_step: command -v mempalace"
  echo "[memory] rollback_cleanup: remove mempalace artifacts if verification fails"
  run_id="$(create_plan_record "memory install" "mempalace" "memory augmentation" "system binary" true true "planned MemPalace memory augmentation")"
  target_summary="host=$(hostname 2>/dev/null || echo unknown) model=mempalace use_case=memory augmentation runtime=system binary"
  plan_record_update "$run_id" target_summary "$target_summary"
  echo "[approval] change_tracking_required: true"
  echo "[approval] approval_required: true"
  echo "[plan] run_id: $run_id"
}

memory_install_execute() {
  local run_id="$1"
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[memory] FAIL: run_id not found"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_state)" != "approved" ]; then
    echo "[memory] FAIL: run is not approved"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"mempalace\",\"status\":\"fail\",\"reason\":\"not approved\",\"timestamp\":\"$(date -Is)\"}"
    plan_record_update "$run_id" overall_status fail
    plan_record_update "$run_id" overall_signal fail
    plan_record_update "$run_id" ended_at "$(date -Is)"
    plan_record_update "$run_id" reason_for_stop memory_failed
    plan_record_update "$run_id" verified false
    plan_record_update "$run_id" verification_output_summary "MemPalace approval missing"
    memory_sync_run_record "$run_id"
    return 1
  fi
  echo "[memory] executing approved MemPalace augmentation"
  echo "[memory] run_id: $run_id"
  echo "[memory] model_id: mempalace"
  echo "[memory] use_case: memory augmentation"
  echo "[memory] verification_step: command -v mempalace"
  echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
  plan_record_update "$run_id" overall_status running
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"mempalace\",\"status\":\"executing\",\"timestamp\":\"$(date -Is)\"}"
  if ! command -v mempalace >/dev/null 2>&1; then
    echo "[memory] FAIL: MemPalace not detected"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"mempalace\",\"status\":\"fail\",\"reason\":\"missing mempalace\",\"timestamp\":\"$(date -Is)\"}"
    plan_record_update "$run_id" overall_status fail
    plan_record_update "$run_id" overall_signal fail
    plan_record_update "$run_id" ended_at "$(date -Is)"
    plan_record_update "$run_id" reason_for_stop memory_failed
    plan_record_update "$run_id" verified false
    plan_record_update "$run_id" verification_output_summary "MemPalace not installed"
    memory_sync_run_record "$run_id"
    return 1
  fi
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"mempalace\",\"status\":\"pass\",\"timestamp\":\"$(date -Is)\"}"
  plan_record_update "$run_id" overall_status pass
  plan_record_update "$run_id" overall_signal ok
  plan_record_update "$run_id" ended_at "$(date -Is)"
  plan_record_update "$run_id" reason_for_stop completed
  plan_record_update "$run_id" verified true
  plan_record_update "$run_id" verification_output_summary "MemPalace detected and ready"
  memory_sync_run_record "$run_id"
  memory_refresh_reflections
  echo "[memory] verified: true"
  echo "[memory] suggestion: memory mode hybrid"
}

bootstrap_plan() {
  local dep status run_id target_summary
  echo "[bootstrap] present/missing/optional/blocked"
  for dep in git curl bash ssh ollama; do
    if command -v "$dep" >/dev/null 2>&1; then
      status="present"
    else
      case "$dep" in
        ollama) status="optional" ;;
        *) status="missing" ;;
      esac
    fi
    printf '%s: %s\n' "$dep" "$status"
  done
  if memory_backend_available; then
    echo "[bootstrap] mempalace: detected"
  else
    echo "[bootstrap] mempalace: not detected"
    echo "[bootstrap] NOMAD native memory is active and sufficient"
    echo "[bootstrap] MemPalace can be installed for extended recall and semantic memory"
    echo "[bootstrap] action: memory plan-install mempalace"
  fi
  echo "state_dir: present"
  run_id="$(create_plan_record "bootstrap install" "normad-bootstrap" "bootstrap" "custom" true true "bootstrap plan")"
  target_summary="host=$(hostname 2>/dev/null || echo unknown) action=bootstrap install"
  plan_record_update "$run_id" target_summary "$target_summary"
  memory_sync_run_record "$run_id"
  echo "[plan] run_id: $run_id"
  echo "[approval] change_tracking_required: true"
  echo "[approval] approval_required: true"
}

bootstrap_install() {
  local run_id="$1"
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[bootstrap] FAIL: run_id not found"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_required)" != "true" ]; then
    echo "[bootstrap] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_state)" != "approved" ]; then
    echo "[bootstrap] FAIL: run is not approved"
    return 1
  fi
  echo "[bootstrap] executing approved bootstrap plan"
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"normad-bootstrap\",\"status\":\"executing\",\"timestamp\":\"$(date -Is)\"}"
  plan_record_update "$run_id" overall_status running
  echo "[bootstrap] preflight: running"
  echo "[bootstrap] dependency_install: running"
  echo "[bootstrap] runtime_verify: running"
  echo "[bootstrap] model_ready_verify: running"
  echo "[bootstrap] continue_setup: running"
  if ! command -v git >/dev/null 2>&1 || ! command -v curl >/dev/null 2>&1 || ! command -v bash >/dev/null 2>&1 || ! command -v ssh >/dev/null 2>&1; then
    echo "[bootstrap] FAIL: required bootstrap dependency missing"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"normad-bootstrap\",\"status\":\"fail\",\"reason\":\"bootstrap dependency missing\",\"timestamp\":\"$(date -Is)\"}"
    plan_record_update "$run_id" overall_status fail
    plan_record_update "$run_id" overall_signal fail
    plan_record_update "$run_id" ended_at "$(date -Is)"
    plan_record_update "$run_id" reason_for_stop bootstrap_failed
    plan_record_update "$run_id" verified false
    plan_record_update "$run_id" verification_output_summary "bootstrap prerequisites missing"
    memory_sync_run_record "$run_id"
    memory_refresh_reflections
    return 1
  fi
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"normad-bootstrap\",\"status\":\"pass\",\"timestamp\":\"$(date -Is)\"}"
  plan_record_update "$run_id" overall_status pass
  plan_record_update "$run_id" overall_signal ok
  plan_record_update "$run_id" ended_at "$(date -Is)"
  plan_record_update "$run_id" reason_for_stop completed
  plan_record_update "$run_id" verified true
  plan_record_update "$run_id" verification_output_summary "bootstrap prerequisites verified"
  memory_sync_run_record "$run_id"
  memory_refresh_reflections
  echo "[bootstrap] verified: true"
}

plan_run() {
  local workflow_name="$1"
  local run_id
  run_id="$(create_plan_record "plan run" "$workflow_name" "workflow planning" "custom" true true "workflow approval gate")"
  memory_sync_run_record "$run_id"
  echo "[plan] workflow: $workflow_name"
  echo "[plan] run_id: $run_id"
  echo "[approval] change_tracking_required: true"
  echo "[approval] approval_required: true"
}

approve_run() {
  local run_id="$1"
  if ! plan_record_exists "$run_id"; then
    echo "[approval] FAIL: run_id not found"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_required)" != "true" ]; then
    echo "[approval] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" overall_status)" = "pass" ] || [ "$(plan_record_get "$run_id" overall_status)" = "fail" ] || [ "$(plan_record_get "$run_id" approval_state)" = "denied" ]; then
    echo "[approval] FAIL: run is already completed or denied"
    return 1
  fi
  plan_record_update "$run_id" approval_state approved
  memory_sync_run_record "$run_id"
  memory_sync_approval_record "$run_id" approved
  memory_refresh_reflections
  echo "[approval] run_id: $run_id"
  echo "[approval] status: approved"
}

deny_run() {
  local run_id="$1"
  if ! plan_record_exists "$run_id"; then
    echo "[approval] FAIL: run_id not found"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_required)" != "true" ]; then
    echo "[approval] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" overall_status)" = "pass" ] || [ "$(plan_record_get "$run_id" overall_status)" = "fail" ] || [ "$(plan_record_get "$run_id" approval_state)" = "denied" ]; then
    echo "[approval] FAIL: run is already completed or denied"
    return 1
  fi
  plan_record_update "$run_id" approval_state denied
  memory_sync_run_record "$run_id"
  memory_sync_approval_record "$run_id" denied
  memory_refresh_reflections
  echo "[approval] run_id: $run_id"
  echo "[approval] status: denied"
}

install_model_if_approved() {
  local run_id="$1"
  local model_id approval_state approval_required verify_command install_method
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[install] FAIL: run_id not found"
    return 1
  fi
  model_id="$(plan_record_get "$run_id" model_id)"
  approval_state="$(plan_record_get "$run_id" approval_state)"
  approval_required="$(plan_record_get "$run_id" approval_required)"
  verify_command="$(get_model_field "$model_id" verify_command)"
  install_method="$(get_model_field "$model_id" install_method)"
  if [ "$approval_required" != "true" ]; then
    echo "[install] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$approval_state" != "approved" ]; then
    echo "[install] FAIL: run is not approved"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"blocked\",\"reason\":\"not approved\",\"timestamp\":\"$(date -Is)\"}"
    return 1
  fi
  if ! model_fits_hardware "$model_id"; then
    echo "[install] FAIL: model is not a safe hardware fit"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"blocked\",\"reason\":\"hardware mismatch\",\"timestamp\":\"$(date -Is)\"}"
    return 1
  fi
  echo "[install] run_id: $run_id"
  echo "[install] model_id: $model_id"
  echo "[install] install_method: $install_method"
  echo "[install] verification_step: $verify_command"
  echo "[install] approval_required: true"
  echo "[install] approval_status: approved"
  echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"executing\",\"timestamp\":\"$(date -Is)\"}"
  echo "[install] execution: pending verification in /run resume $run_id"
}

install_bootstrap_if_approved() {
  local run_id="$1"
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[install] FAIL: run_id not found"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_required)" != "true" ]; then
    echo "[install] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$(plan_record_get "$run_id" approval_state)" != "approved" ]; then
    echo "[install] FAIL: run is not approved"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    return 1
  fi
  echo "[install] run_id: $run_id"
  echo "[install] approval_required: true"
  echo "[install] approval_status: approved"
  echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"normad-bootstrap\",\"status\":\"executing\",\"timestamp\":\"$(date -Is)\"}"
  echo "[install] execution: deferred to /run resume $run_id"
}

model_install_execute() {
  local run_id="$1"
  local model_id verify_command install_method verdict status
  if [ -z "$run_id" ] || ! plan_record_exists "$run_id"; then
    echo "[run] FAIL: run_id not found"
    return 1
  fi
  model_id="$(plan_record_get "$run_id" model_id)"
  verify_command="$(get_model_field "$model_id" verify_command)"
  install_method="$(get_model_field "$model_id" install_method)"
  echo "[install] run_id: $run_id"
  echo "[install] model_id: $model_id"
  echo "[install] install_method: $install_method"
  echo "[install] verification_step: $verify_command"
  if [ -z "$verify_command" ]; then
    echo "[install] FAIL: verification step missing"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"fail\",\"reason\":\"missing verification step\",\"timestamp\":\"$(date -Is)\"}"
    return 1
  fi
  verdict="$(validator_check "$verify_command" || true)"
  echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then
    echo "[install] FAIL: verification command rejected"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"fail\",\"reason\":\"verification rejected\",\"timestamp\":\"$(date -Is)\"}"
    return 1
  fi
  echo; echo "[exec] $verify_command"; echo
  if ! shell_command_allowed "$verify_command"; then
    echo "[install] FAIL: verification command rejected"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"fail\",\"reason\":\"verification rejected\",\"timestamp\":\"$(date -Is)\"}"
    return 1
  fi
  bash --noprofile --norc -c "$verify_command" > "$CMD_OUTPUT_FILE" 2>&1
  status=$?
  echo "--- OUTPUT START ---"; cat "$CMD_OUTPUT_FILE"; echo "--- OUTPUT END ---"; echo
  if [ "$status" -ne 0 ]; then
    echo "[install] FAIL: verification command failed"
    echo "[restore] cleanup_path: $(restore_cleanup_path "$run_id")"
    memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"fail\",\"reason\":\"verification failed\",\"timestamp\":\"$(date -Is)\"}"
    plan_record_update "$run_id" overall_status fail
    plan_record_update "$run_id" overall_signal fail
    plan_record_update "$run_id" ended_at "$(date -Is)"
    plan_record_update "$run_id" reason_for_stop verification_failed
    plan_record_update "$run_id" verified false
    memory_sync_run_record "$run_id"
    return 1
  fi
  memory_record_install_result "$run_id" "{\"run_id\":\"$run_id\",\"model_id\":\"$model_id\",\"status\":\"verified\",\"timestamp\":\"$(date -Is)\"}"
  plan_record_update "$run_id" overall_status pass
  plan_record_update "$run_id" overall_signal ok
  plan_record_update "$run_id" ended_at "$(date -Is)"
  plan_record_update "$run_id" reason_for_stop completed
  plan_record_update "$run_id" verified true
  plan_record_update "$run_id" verification_output_summary "verified: $verify_command"
  memory_sync_run_record "$run_id"
  echo "[install] verified: true"
}

write_lesson() {
  local line="$1"
  printf '%s | %s\n' "$(date -Is)" "$line" >> "$LESSONS_FILE"
}

workflow_prod_baseline_steps() {
  cat <<'EOF'
1|ssh audit example-target|/ssh-audit example-target
2|apache/php audit example-target|/exec-task apache php audit example-target
3|diff prod test|/exec-task diff prod test
EOF
}

workflow_prod_investigate_last_night_steps() {
  cat <<'EOF'
1|what happened last night|/exec-task investigate example-target last night logs
2|apache/php audit example-target|/exec-task apache php audit example-target
3|diff prod test webroot|/exec-task diff prod test /srv/example/prod /srv/example/test
EOF
}

workflow_test_vs_prod_webroot_steps() {
  cat <<'EOF'
1|diff prod test webroot|/exec-task diff prod test /srv/example/prod /srv/example/test
EOF
}

workflow_prod_health_decision_steps() {
  cat <<'EOF'
1|ssh audit example-target|/ssh-audit example-target|workflow_step_1_next_pass=2|workflow_step_1_continue_on_fail=false
2|apache/php audit example-target|/exec-task apache php audit example-target|workflow_step_2_next_pass=3|workflow_step_2_on_fail=STOP|workflow_step_2_continue_on_fail=false
3|diff prod test|/exec-task diff prod test|workflow_step_3_on_empty=PASS_NOTE_NO_NOTABLE_STRUCTURAL_DIFFERENCES|workflow_step_3_on_pass=END
EOF
}

workflow_investigate_or_compare_steps() {
  cat <<'EOF'
1|what happened last night|/exec-task investigate example-target last night logs|workflow_step_1_on_empty=2|workflow_step_1_on_review=END_REVIEW|workflow_step_1_on_fail=STOP
2|diff prod test webroot|/exec-task diff prod test /srv/example/prod /srv/example/test|workflow_step_2_on_empty=END_EMPTY|workflow_step_2_on_pass=END_OK
EOF
}

workflow_test_vs_prod_decision_steps() {
  cat <<'EOF'
1|diff prod test webroot|/exec-task diff prod test /srv/example/prod /srv/example/test|workflow_step_1_on_empty=END_EMPTY|workflow_step_1_on_review=END_REVIEW|workflow_step_1_on_pass=END_OK
EOF
}

workflow_registry_list() {
  cat <<'EOF'
workflow_prod_baseline
workflow_prod_investigate_last_night
workflow_test_vs_prod_webroot
workflow_prod_health_decision
workflow_investigate_or_compare
workflow_test_vs_prod_decision
EOF
}

workflow_steps_for() {
  case "$1" in
    workflow_prod_baseline) workflow_prod_baseline_steps ;;
    workflow_prod_investigate_last_night) workflow_prod_investigate_last_night_steps ;;
    workflow_test_vs_prod_webroot) workflow_test_vs_prod_webroot_steps ;;
    workflow_prod_health_decision) workflow_prod_health_decision_steps ;;
    workflow_investigate_or_compare) workflow_investigate_or_compare_steps ;;
    workflow_test_vs_prod_decision) workflow_test_vs_prod_decision_steps ;;
    *) return 1 ;;
  esac
}

workflow_step_meta_value() {
  local meta_line="$1"
  local key="$2"
  local pair
  for pair in ${meta_line//|/ }; do
    case "$pair" in
      "$key="*) printf '%s\n' "${pair#*=}"; return 0 ;;
    esac
  done
  return 1
}

normalize_step_output() {
  local step_kind="$1"
  local step_output="$2"
  local step_status="$3"
  local summary_line=""
  local step_signal="review"
  local raw_ref="$4"
  local apache_ver php_ver http_status prod_count test_count cron_count hist_count app_count

  summary_line="$(printf '%s\n' "$step_output" | awk 'NF {print; exit}')"
  [ -z "$summary_line" ] && summary_line="no output"

  case "$step_kind" in
    apache_php_audit)
      apache_ver="$(printf '%s\n' "$step_output" | sed -nE 's/^Apache: (.*)$/\1/p' | head -n 1)"
      php_ver="$(printf '%s\n' "$step_output" | sed -nE 's/^PHP: (.*)$/\1/p' | head -n 1)"
      http_status="$(printf '%s\n' "$step_output" | sed -nE 's/^HTTP: (.*)$/\1/p' | head -n 1)"
      if [ "${http_status:-}" = "200" ] && [ -n "${apache_ver:-}" ] && [ -n "${php_ver:-}" ]; then
        step_signal="ok"
      else
        step_signal="fail"
      fi
      ;;
    diff_structural)
      if printf '%s\n' "$step_output" | grep -Eq '^[<>]|^diff |^Only in '; then
        step_signal="ok"
      else
        step_signal="empty"
      fi
      ;;
    diff_scoped)
      if printf '%s\n' "$step_output" | awk '
        /^\[prod files\]$/ { section="prod"; next }
        /^\[test files\]$/ { section="test"; next }
        /^$/ { next }
        section=="prod" && NF { prod=1 }
        section=="test" && NF { test=1 }
        END { if (prod) print "prod"; if (test) print "test" }
      ' | grep -q '^prod$'; then
        prod_count=1
      else
        prod_count=0
      fi
      if printf '%s\n' "$step_output" | awk '
        /^\[prod files\]$/ { section="prod"; next }
        /^\[test files\]$/ { section="test"; next }
        /^$/ { next }
        section=="test" && NF { test=1 }
        END { if (test) print "test" }
      ' | grep -q '^test$'; then
        test_count=1
      else
        test_count=0
      fi
      if [ "$prod_count" -eq 0 ] && [ "$test_count" -eq 0 ]; then
        step_signal="empty"
      elif [ "$prod_count" -eq 0 ] || [ "$test_count" -eq 0 ]; then
        step_signal="review"
      else
        step_signal="ok"
      fi
      ;;
    investigate_last_night)
      cron_count="$(printf '%s\n' "$step_output" | grep -ci 'cron-related evidence was returned\|CRON / SCHEDULER SIGNALS\|CRON')"
      hist_count="$(printf '%s\n' "$step_output" | grep -ci 'shell history evidence was returned\|SHELL HISTORY')"
      app_count="$(printf '%s\n' "$step_output" | grep -ci 'Recent file modifications were returned\|app-specific logs\|service timers')"
      if [ "$cron_count" -eq 0 ] && [ "$hist_count" -eq 0 ] && [ "$app_count" -eq 0 ]; then
        step_signal="empty"
      else
        step_signal="review"
      fi
      ;;
    *)
      if [ "$step_status" = "pass" ]; then
        step_signal="ok"
      elif [ "$step_status" = "skip" ]; then
        step_signal="empty"
      else
        step_signal="fail"
      fi
      ;;
  esac

  if [ "$step_kind" = "diff_structural" ] && [ -z "$step_output" ]; then
    step_signal="empty"
  fi

  printf '%s|%s|%s|%s\n' "$step_status" "$step_signal" "$summary_line" "$raw_ref"
}

workflow_step_kind_for_command() {
  local step_command="$1"
  case "$step_command" in
    "/exec-task apache php audit example-target") printf '%s\n' "apache_php_audit" ;;
    "/exec-task diff prod test") printf '%s\n' "diff_structural" ;;
    "/exec-task diff prod test /srv/example/prod /srv/example/test") printf '%s\n' "diff_scoped" ;;
    "/exec-task investigate example-target last night logs") printf '%s\n' "investigate_last_night" ;;
    *) printf '%s\n' "generic" ;;
  esac
}

workflow_step_execute() {
  local step_command="$1"
  local step_output step_status
  step_output="$(workflow_step_dispatch "$step_command" 2>&1)"
  step_status=$?
  printf '%s\n' "$step_output"
  return "$step_status"
}

workflow_decision_explain() {
  local workflow_name="$1"
  local steps
  steps="$(workflow_steps_for "$workflow_name" 2>/dev/null || true)"
  if [ -z "$steps" ]; then
    echo "unknown workflow"
    return 1
  fi

  echo "[decision] workflow: $workflow_name"
  printf '%s\n' "$steps" | while IFS='|' read -r step_no step_label step_command step_meta; do
    [ -z "${step_no:-}" ] && continue
    echo "step $step_no: $step_label"
    echo "command: $step_command"
    echo "on_pass: $(workflow_step_meta_value "${step_meta:-}" "workflow_step_${step_no}_on_pass" 2>/dev/null || echo continue)"
    echo "on_fail: $(workflow_step_meta_value "${step_meta:-}" "workflow_step_${step_no}_on_fail" 2>/dev/null || echo stop)"
    echo "on_empty: $(workflow_step_meta_value "${step_meta:-}" "workflow_step_${step_no}_on_empty" 2>/dev/null || echo stop)"
    echo "continue_on_fail: $(workflow_step_meta_value "${step_meta:-}" "workflow_step_${step_no}_continue_on_fail" 2>/dev/null || echo false)"
    echo
  done
}

workflow_record_step_json() {
  local run_file="$1"
  local run_id="$2"
  local workflow_name="$3"
  local step_no="$4"
  local step_label="$5"
  local step_command="$6"
  local step_status="$7"
  local step_signal="$8"
  local summary_line="$9"
  local branch_target="${10:-}"
  local raw_ref="${11:-}"
  printf '{"run_id":"%s","workflow_name":"%s","step_no":"%s","label":"%s","command":"%s","status":"%s","signal":"%s","summary":"%s","branch_target":"%s","raw_output_ref":"%s","timestamp":"%s"}\n' \
    "$run_id" "$workflow_name" "$step_no" "$step_label" "$step_command" "$step_status" "$step_signal" "$summary_line" "$branch_target" "$raw_ref" "$(date -Is)" >> "$run_file"
}

workflow_record_final_json() {
  local run_file="$1"
  local run_id="$2"
  local workflow_name="$3"
  local started_at="$4"
  local ended_at="$5"
  local overall_status="$6"
  local overall_signal="$7"
  local reason_for_stop="$8"
  local same_host_warning="${9:-false}"
  printf '{"run_id":"%s","workflow_name":"%s","started_at":"%s","ended_at":"%s","overall_status":"%s","overall_signal":"%s","reason_for_stop":"%s","same_host_warning":%s}\n' \
    "$run_id" "$workflow_name" "$started_at" "$ended_at" "$overall_status" "$overall_signal" "$reason_for_stop" "$same_host_warning" >> "$run_file"
}

workflow_branch_decide() {
  local workflow_name="$1"
  local step_no="$2"
  local step_status="$3"
  local step_signal="$4"
  local step_meta="$5"
  local branch_target=""
  local decision=""

  case "$step_status:$step_signal" in
    pass:ok|pass:empty|pass:review)
      branch_target="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_pass" 2>/dev/null || true)"
      ;;
    fail:*)
      branch_target="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_fail" 2>/dev/null || true)"
      ;;
    skip:*)
      branch_target="END"
      ;;
    *)
      branch_target=""
      ;;
  esac

  if [ "$step_signal" = "empty" ]; then
    decision="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_empty" 2>/dev/null || true)"
    [ -n "$decision" ] && branch_target="$decision"
  fi
  if [ "$step_signal" = "review" ]; then
    decision="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_review" 2>/dev/null || true)"
    [ -n "$decision" ] && branch_target="$decision"
  fi
  if [ -z "$branch_target" ]; then
    branch_target="NEXT"
  fi

  printf '%s\n' "$branch_target"
}

workflow_smart_run() {
  local workflow_name="$1"
  local steps run_id started_at ended_at overall_status overall_signal reason_for_stop run_file
  local idx step_no step_label step_command step_meta step_kind
  local step_output step_status step_signal summary_line raw_ref branch_target
  local step_lines=()
  local branch_key branch_value next_step_no next_index found_next

  steps="$(workflow_steps_for "$workflow_name" 2>/dev/null || true)"
  if [ -z "$steps" ]; then
    echo "unknown workflow"
    return 1
  fi

  run_id="$(date +%Y%m%d-%H%M%S)-$$-smart"
  started_at="$(date -Is)"
  run_file="$(workflow_record_path "$run_id")"
  overall_status="running"
  overall_signal="review"
  reason_for_stop="completed"

  : > "$run_file"

  mapfile -t step_lines <<< "$steps"

  echo "[workflow] run_id: $run_id"
  echo "[workflow] workflow_name: $workflow_name"
  echo "[workflow] started_at: $started_at"
  echo "[identity] NOMAD - autonomous orchestrator (validated execution)"
  echo

  idx=0
  while [ "$idx" -lt "${#step_lines[@]}" ]; do
    IFS='|' read -r step_no step_label step_command step_meta <<< "${step_lines[$idx]}"
    [ -z "${step_no:-}" ] && { idx=$((idx+1)); continue; }

    step_kind="$(workflow_step_kind_for_command "$step_command")"
    echo "=================================================="
    echo "[step $step_no] $step_label"
    echo "command: $step_command"
    echo "status: running"

    if step_output="$(workflow_step_execute "$step_command")"; then
      step_status="pass"
    else
      step_status="fail"
    fi

    raw_ref="$run_file#step-$step_no"
    IFS='|' read -r step_status step_signal summary_line _ <<< "$(normalize_step_output "$step_kind" "$step_output" "$step_status" "$raw_ref")"

    if [ "$step_status" = "pass" ] && [ "$step_kind" = "diff_structural" ] && [ "$step_signal" = "empty" ]; then
      summary_line="no notable structural differences"
    fi

    branch_target="$(workflow_branch_decide "$workflow_name" "$step_no" "$step_status" "$step_signal" "$step_meta")"
    echo "status: ${step_status^^}"
    echo "signal: $step_signal"
    echo "branch: $branch_target"
    [ -n "$summary_line" ] && echo "summary: $summary_line"
    echo "$step_output"

    workflow_record_step_json "$run_file" "$run_id" "$workflow_name" "$step_no" "$step_label" "$step_command" "$step_status" "$step_signal" "$summary_line" "$branch_target" "$raw_ref"

    if [ "$step_status" = "fail" ] && [ "${branch_target:-STOP}" != "NEXT" ] && [ "${branch_target:-STOP}" != "END" ]; then
      reason_for_stop="step $step_no failed"
      overall_status="fail"
      overall_signal="fail"
      break
    fi

    if [ "$step_signal" = "review" ] && [ "${branch_target:-STOP}" = "END_REVIEW" ]; then
      reason_for_stop="review decision at step $step_no"
      overall_status="pass"
      overall_signal="review"
      break
    fi

    if [ "$step_signal" = "empty" ] && [ "${branch_target:-STOP}" = "END_EMPTY" ]; then
      reason_for_stop="empty decision at step $step_no"
      overall_status="pass"
      overall_signal="empty"
      break
    fi

    if [ "$step_status" = "pass" ] && [ "$step_kind" = "apache_php_audit" ] && [ "$step_signal" != "ok" ]; then
      reason_for_stop="apache/php audit incomplete at step $step_no"
      overall_status="fail"
      overall_signal="$step_signal"
      break
    fi

    if [ "$step_kind" = "investigate_last_night" ] && [ "$step_signal" = "empty" ]; then
      branch_target="${branch_target:-2}"
    fi

    if [ "$branch_target" = "END_OK" ]; then
      reason_for_stop="workflow ended after step $step_no"
      overall_status="pass"
      overall_signal="$step_signal"
      break
    fi

    if [ "$branch_target" = "STOP" ] || [ "$branch_target" = "END" ]; then
      reason_for_stop="workflow stopped at step $step_no"
      if [ "$step_status" = "fail" ]; then
        overall_status="fail"
        overall_signal="fail"
      else
        overall_status="pass"
        overall_signal="$step_signal"
      fi
      break
    fi

    if [ "$branch_target" = "PASS_NOTE_NO_NOTABLE_STRUCTURAL_DIFFERENCES" ]; then
      reason_for_stop="no notable structural differences"
      overall_status="pass"
      overall_signal="empty"
      break
    fi

    if [ "$step_signal" = "fail" ] && [ "$step_status" = "pass" ]; then
      reason_for_stop="step $step_no failed validation"
      overall_status="fail"
      overall_signal="fail"
      break
    fi

    next_step_no=""
    case "$step_status:$step_signal" in
      pass:ok)
        next_step_no="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_pass" 2>/dev/null || true)"
        ;;
      pass:empty)
        next_step_no="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_empty" 2>/dev/null || true)"
        ;;
      pass:review)
        next_step_no="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_review" 2>/dev/null || true)"
        ;;
      fail:*)
        next_step_no="$(workflow_step_meta_value "$step_meta" "workflow_step_${step_no}_on_fail" 2>/dev/null || true)"
        ;;
    esac
    [ -z "$next_step_no" ] && next_step_no="NEXT"

    if [ "$next_step_no" = "NEXT" ]; then
      idx=$((idx+1))
      continue
    fi

    if [ "$next_step_no" = "END" ] || [ "$next_step_no" = "STOP" ]; then
      reason_for_stop="workflow stopped at step $step_no"
      [ "$step_signal" = "review" ] && overall_signal="review"
      [ "$step_signal" = "empty" ] && overall_signal="empty"
      [ "$step_signal" = "ok" ] && overall_signal="ok"
      [ "$step_status" = "fail" ] && overall_status="fail" || overall_status="pass"
      break
    fi

    found_next=0
    for next_index in "${!step_lines[@]}"; do
      IFS='|' read -r branch_key branch_value branch_point _ <<< "${step_lines[$next_index]}"
      if [ "$branch_key" = "$next_step_no" ]; then
        idx="$next_index"
        found_next=1
        break
      fi
    done

    if [ "$found_next" -eq 1 ]; then
      continue
    fi

    reason_for_stop="branch target $next_step_no not found"
    overall_status="fail"
    overall_signal="fail"
    break
  done

  ended_at="$(date -Is)"
  if [ "$overall_status" = "running" ]; then
    overall_status="pass"
  fi
  [ -z "$reason_for_stop" ] && reason_for_stop="completed"
  workflow_record_final_json "$run_file" "$run_id" "$workflow_name" "$started_at" "$ended_at" "$overall_status" "$overall_signal" "$reason_for_stop"
  printf '%s\n' "$run_id" > "$JOVOCODER_LAST_RUN_FILE"

  echo "=================================================="
  echo "[workflow] ended_at: $ended_at"
  echo "[workflow] overall_status: $overall_status"
  echo "[workflow] overall_signal: $overall_signal"
  echo "[workflow] reason_for_stop: $reason_for_stop"
  echo "[workflow] run_record: $run_file"
}

workflow_show() {
  local workflow_name="$1"
  local steps
  steps="$(workflow_steps_for "$workflow_name" 2>/dev/null || true)"
  if [ -z "$steps" ]; then
    echo "unknown workflow"
    return 1
  fi
  echo "[workflow] $workflow_name"
  printf '%s\n' "$steps" | while IFS='|' read -r step_no step_label step_command; do
    [ -z "${step_no:-}" ] && continue
    printf '%s. %s\n' "$step_no" "$step_label"
    printf '   command: %s\n' "$step_command"
  done
}

workflow_record_path() {
  local run_id="$1"
  printf '%s/%s.jsonl' "$JOVOCODER_RUNS_DIR" "$run_id"
}

workflow_write_record() {
  local run_file="$1"
  shift
  printf '%s\n' "$@" >> "$run_file"
}

workflow_step_dispatch() {
  local step_command="$1"
  case "$step_command" in
    "/ssh-audit example-target")
      local resolved
      resolved="$(resolve_safe_target "example-target" 2>/dev/null || true)"
      if [ -z "$resolved" ] || [ "$resolved" = "NOT_FOUND" ] || [ "$resolved" = "UNSAFE" ] || [ "$resolved" = "NO_CONFIG" ]; then
        return 1
      fi
      CMD="ssh -n $resolved 'hostname && uptime && df -h'"
      verdict="$(validator_check "$CMD" || true)"; echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then
        run_command "$CMD"
        return 0
      fi
      return 1
      ;;
    "/exec-task apache php audit example-target")
      local resolved
      local step_output
      resolved="$(resolve_safe_target "example-target" 2>/dev/null || true)"
      if [ -z "$resolved" ] || [ "$resolved" = "NOT_FOUND" ] || [ "$resolved" = "UNSAFE" ] || [ "$resolved" = "NO_CONFIG" ]; then
        return 1
      fi
      step_output="$(run_remote_apache_php_audit "$resolved" "example-target" 2>&1)"
      printf '%s\n' "$step_output"
      if printf '%s\n' "$step_output" | grep -q '^Status: PASS'; then
        return 0
      fi
      return 1
      ;;
    "/exec-task diff prod test")
      exec_task "diff prod test"
      return $?
      ;;
    "/exec-task diff prod test /srv/example/prod /srv/example/test")
      exec_task "diff prod test /srv/example/prod /srv/example/test"
      return $?
      ;;
    "/exec-task investigate example-target last night logs")
      exec_task "investigate example-target last night logs"
      return $?
      ;;
    *)
      exec_task "${step_command#"/exec-task "}"
      return $?
      ;;
  esac
}

workflow_run() {
  local workflow_name="$1"
  local steps run_id started_at ended_at overall_status run_file
  local step_no step_label step_command step_status
  local failed=0
  local idx
  local step_lines=()

  steps="$(workflow_steps_for "$workflow_name" 2>/dev/null || true)"
  if [ -z "$steps" ]; then
    echo "unknown workflow"
    return 1
  fi

  run_id="$(date +%Y%m%d-%H%M%S)-$$"
  started_at="$(date -Is)"
  run_file="$(workflow_record_path "$run_id")"
  overall_status="running"

  : > "$run_file"
  workflow_write_record "$run_file" \
    "{\"run_id\":\"$run_id\",\"workflow_name\":\"$workflow_name\",\"started_at\":\"$started_at\",\"ended_at\":\"\",\"overall_status\":\"running\"}"

  echo "[workflow] run_id: $run_id"
  echo "[workflow] workflow_name: $workflow_name"
  echo "[workflow] started_at: $started_at"
  echo "[identity] NOMAD - autonomous orchestrator (validated execution)"
  echo

  mapfile -t step_lines <<< "$steps"
  for idx in "${!step_lines[@]}"; do
    IFS='|' read -r step_no step_label step_command <<< "${step_lines[$idx]}"
    [ -z "${step_no:-}" ] && continue
    step_status="pending"
    echo "=================================================="
    echo "[step $step_no] $step_label"
    echo "command: $step_command"
    echo "status: running"
    step_status="running"
    if workflow_step_dispatch "$step_command"; then
      step_status="pass"
      echo "status: PASS"
    else
      step_status="fail"
      echo "status: FAIL"
      overall_status="fail"
      workflow_write_record "$run_file" \
        "{\"run_id\":\"$run_id\",\"workflow_name\":\"$workflow_name\",\"step_no\":\"$step_no\",\"label\":\"$step_label\",\"command\":\"$step_command\",\"status\":\"$step_status\",\"timestamp\":\"$(date -Is)\"}"
      failed=1
      break
    fi
    workflow_write_record "$run_file" \
      "{\"run_id\":\"$run_id\",\"workflow_name\":\"$workflow_name\",\"step_no\":\"$step_no\",\"label\":\"$step_label\",\"command\":\"$step_command\",\"status\":\"$step_status\",\"timestamp\":\"$(date -Is)\"}"
  done

  if [ "$failed" -eq 1 ]; then
    for ((idx=idx+1; idx<${#step_lines[@]}; idx++)); do
      IFS='|' read -r step_no step_label step_command <<< "${step_lines[$idx]}"
      [ -z "${step_no:-}" ] && continue
      workflow_write_record "$run_file" \
        "{\"run_id\":\"$run_id\",\"workflow_name\":\"$workflow_name\",\"step_no\":\"$step_no\",\"label\":\"$step_label\",\"command\":\"$step_command\",\"status\":\"skipped\",\"timestamp\":\"$(date -Is)\"}"
      echo "=================================================="
      echo "[step $step_no] $step_label"
      echo "command: $step_command"
      echo "status: SKIPPED"
    done
  fi

  ended_at="$(date -Is)"
  if [ "$overall_status" = "running" ]; then
    overall_status="pass"
  fi

  workflow_write_record "$run_file" \
    "{\"run_id\":\"$run_id\",\"workflow_name\":\"$workflow_name\",\"started_at\":\"$started_at\",\"ended_at\":\"$ended_at\",\"overall_status\":\"$overall_status\"}"
  printf '%s\n' "$run_id" > "$JOVOCODER_LAST_RUN_FILE"

  echo "=================================================="
  echo "[workflow] ended_at: $ended_at"
  echo "[workflow] overall_status: $overall_status"
  echo "[workflow] run_record: $run_file"
}

workflow_list() {
  workflow_registry_list
}

run_last_workflow() {
  local run_id
  if [ ! -f "$JOVOCODER_LAST_RUN_FILE" ]; then
    echo "no run record"
    return 1
  fi
  run_id="$(cat "$JOVOCODER_LAST_RUN_FILE" 2>/dev/null || true)"
  [ -z "$run_id" ] && { echo "no run record"; return 1; }
  workflow_show_run "$run_id"
}

workflow_show_run() {
  local run_id="$1"
  local run_file
  run_file="$(workflow_record_path "$run_id")"
  if [ ! -f "$run_file" ]; then
    echo "unknown run"
    return 1
  fi
  cat "$run_file"
}

run_record_show() {
  local run_id="$1"
  local run_file
  run_file="$(plan_record_path "$run_id")"
  if [ ! -f "$run_file" ]; then
    echo "unknown run"
    return 1
  fi
  python3 - "$run_file" <<'PY'
import json, sys, pathlib
path = pathlib.Path(sys.argv[1])
data = json.loads(path.read_text())
overall_status = data.get('overall_status') or 'planned'
approval_state = data.get('approval_state') or 'pending'
print(f"run_id: {data.get('run_id','')}")
print(f"action: {data.get('action','')}")
if data.get('workflow_name'):
    print(f"workflow_name: {data.get('workflow_name')}")
if data.get('model_id'):
    print(f"model_id: {data.get('model_id')}")
print(f"started_at: {data.get('started_at', data.get('timestamp',''))}")
print(f"ended_at: {data.get('ended_at','')}")
print(f"overall_status: {overall_status}")
if data.get('overall_signal'):
    print(f"overall_signal: {data.get('overall_signal')}")
print(f"approval_required: {str(data.get('approval_required', False)).lower()}")
print(f"approval_state: {approval_state}")
print(f"change_tracking_required: {str(data.get('change_tracking_required', False)).lower()}")
if data.get('restore_path'):
    print(f"restore_path: {data.get('restore_path')}")
if data.get('reason_for_stop'):
    print(f"reason_for_stop: {data.get('reason_for_stop')}")
if data.get('target_summary'):
    print(f"target_summary: {data.get('target_summary')}")
if data.get('same_host_warning') is not None:
    print(f"same_host_warning: {str(data.get('same_host_warning', False)).lower()}")
steps = data.get('steps') or []
for step in steps:
    print(f"[step] {step}")
PY
}

same_host_warning_for_targets() {
  local prod_resolved="$1"
  local test_resolved="$2"
  if [ -z "$prod_resolved" ] || [ -z "$test_resolved" ]; then
    echo false
    return
  fi
  if [ "$prod_resolved" = "$test_resolved" ]; then
    memory_record_same_host_warning "same-host" "{\"prod\":\"$prod_resolved\",\"test\":\"$test_resolved\",\"same_host_warning\":true,\"timestamp\":\"$(date -Is)\"}"
    memory_record_reflection_event "operational" "$prod_resolved,$test_resolved" "prod and test resolved to the same host" "0.9"
    echo true
  else
    echo false
  fi
}

run_resume() {
  local run_id="$1"
  local action model_id approval_state approval_required overall_status
  if ! plan_record_exists "$run_id"; then
    echo "[run] FAIL: run_id not found"
    return 1
  fi
  action="$(plan_record_get "$run_id" action)"
  model_id="$(plan_record_get "$run_id" model_id)"
  approval_state="$(plan_record_get "$run_id" approval_state)"
  approval_required="$(plan_record_get "$run_id" approval_required)"
  overall_status="$(plan_record_get "$run_id" overall_status)"

  if [ "$approval_required" != "true" ]; then
    echo "[run] FAIL: run is not approval_required"
    return 1
  fi
  if [ "$approval_state" != "approved" ]; then
    echo "[run] FAIL: run is not approved"
    return 1
  fi
  if [ "$overall_status" = "pass" ] || [ "$overall_status" = "fail" ]; then
    echo "[run] FAIL: run is already completed"
    return 1
  fi

  plan_record_update "$run_id" overall_status running
  plan_record_update "$run_id" started_at "$(date -Is)"

  case "$action" in
    "models install")
      install_model_if_approved "$run_id"
      if ! model_install_execute "$run_id"; then
        return 1
      fi
      ;;
    "models update")
      if ! model_update_execute "$run_id"; then
        return 1
      fi
      ;;
    "bootstrap install")
      bootstrap_install "$run_id"
      ;;
    "memory install")
      if ! memory_install_execute "$run_id"; then
        return 1
      fi
      ;;
    "plan run")
      echo "[run] resume: workflow plan execution is not yet implemented"
      return 1
      ;;
    *)
      echo "[run] FAIL: unsupported run action"
      return 1
      ;;
  esac
}

# --- Deterministic audit pack (Apache/PHP) ---
run_remote_apache_php_audit() {
  local resolved="$1"
  local target_label="$2"
  local verdict cmd
  local host_out apache_out php_out http_out
  local apache_ver php_ver http_status

  echo "[exec-task] remote apache/php audit"; echo

  cmd="ssh $resolved 'hostname'"
  verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then echo "[stop] command rejected"; echo; return 1; fi
  run_command "$cmd"; host_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'apache2ctl -v'"
  verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then echo "[stop] command rejected"; echo; return 1; fi
  run_command "$cmd"; apache_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'php -v'"
  verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then echo "[stop] command rejected"; echo; return 1; fi
  run_command "$cmd"; php_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  cmd="ssh $resolved 'curl -sSI http://localhost'"
  verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
  if ! echo "$verdict" | grep -q '^PASS:'; then echo "[stop] command rejected"; echo; return 1; fi
  run_command "$cmd"; http_out="$(cat "$CMD_OUTPUT_FILE" 2>/dev/null || true)"

  apache_ver="$(printf '%s\n' "$apache_out" | sed -nE 's/^Server version: Apache\/([^ ]+).*/\1/p' | head -n 1)"
  php_ver="$(printf '%s\n' "$php_out" | sed -nE 's/^PHP ([^ ]+).*/\1/p' | head -n 1)"
  http_status="$(printf '%s\n' "$http_out" | sed -nE 's/^HTTP\/[^ ]+[[:space:]]+([0-9]{3}).*/\1/p' | head -n 1)"

  echo "[done] apache/php audit sequence completed"; echo
  echo "AUDIT SUMMARY:"
  echo "Target: ${target_label:-unknown}"
  echo "Host: ${host_out%%$'\n'*}"
  echo "Apache: ${apache_ver:-unknown}"
  echo "PHP: ${php_ver:-unknown}"
  echo "HTTP: ${http_status:-unknown}"

  if [ "${http_status:-}" = "200" ] && [ -n "${apache_ver:-}" ] && [ -n "${php_ver:-}" ]; then
    echo "Status: PASS"
    write_lesson "apache/php audit PASS on ${target_label:-unknown}"
  else
    echo "Status: REVIEW"
    # simple failure branching
    if [ "${http_status:-}" != "200" ]; then
      echo; echo "[branch] HTTP not 200 → checking Apache status and logs"
      cmd="ssh $resolved 'systemctl status apache2 --no-pager'"
      verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then run_command "$cmd"; fi
      cmd="ssh $resolved 'tail -n 50 /var/log/apache2/error.log'"
      verdict="$(validator_check "$cmd" || true)"; echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then run_command "$cmd"; fi
    fi
  fi
  echo
}

# --- Explain mode ---
explain_plan_apache_php() {
  local resolved="$1"
  echo "[explain] plan for apache/php audit on $resolved"
  echo "1) ssh $resolved 'hostname'"
  echo "2) ssh $resolved 'apache2ctl -v'"
  echo "3) ssh $resolved 'php -v'"
  echo "4) ssh $resolved 'curl -sSI http://localhost'"
  echo
}

# --- Multi-target (MVP) ---
list_safe_targets() {
  python3 - "$SSH_TARGETS_FILE" <<'PY'
import json, sys, pathlib
cfg = pathlib.Path(sys.argv[1])
if not cfg.exists():
    raise SystemExit(0)
data = json.loads(cfg.read_text())
for alias, t in data.get("targets", {}).items():
    if t.get("safe") is True:
        print(alias)
PY
}

exec_task() {
  local task="$1"
  local task_lc resolved

  task_lc="$(printf '%s' "$task" | tr '[:upper:]' '[:lower:]')"

  # explain mode
  if echo "$task_lc" | grep -q '^explain '; then
    task_lc="${task_lc#explain }"
    if echo "$task_lc" | grep -q "test.example.invalid" && echo "$task_lc" | grep -q "apache" && echo "$task_lc" | grep -q "php"; then
      resolved="$(resolve_safe_target "test.example.invalid" 2>/dev/null || true)"
      [ -z "$resolved" ] && { echo "[validator] FAIL: target not configured safe"; echo; return 1; }
      explain_plan_apache_php "$resolved"
      return 0
    fi
  fi

  # multi-target MVP: "all"
  if echo "$task_lc" | grep -q "all" && echo "$task_lc" | grep -q "apache" && echo "$task_lc" | grep -q "php"; then
    for alias in $(list_safe_targets); do
      resolved="$(resolve_safe_target "$alias" 2>/dev/null || true)"
      [ -z "$resolved" ] && continue
      run_remote_apache_php_audit "$resolved" "$alias"
    done
    return 0
  fi

  # deterministic follow-up execution: cron, logs, files, history
  if echo "$task_lc" | grep -qE "(^|[^[:alnum:]_])(example-target|prod|production|live)([^[:alnum:]_]|$)" && \
     echo "$task_lc" | grep -qE "cron|app|logs|files|history|24|last night"; then

    resolved="$(resolve_safe_target "example-target" 2>/dev/null || true)"
    if [ -z "$resolved" ] || [ "$resolved" = "NOT_FOUND" ] || [ "$resolved" = "UNSAFE" ] || [ "$resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: target not configured safe"; echo; return 1
    fi

    echo "[exec-task] follow-up investigation (24h window)"; echo

    cron_cmd="ssh -n $resolved \"grep -i CRON /var/log/syslog 2>/dev/null | tail -n 80\""
    files_cmd="ssh -n $resolved \"find /var/www/vhosts -type f -mtime -1 2>/dev/null | head -n 50\""
    hist_cmd="ssh -n $resolved \"tail -n 100 /home/exampleuser/.bash_history 2>/dev/null\""

    cron_out="$(ssh -n $resolved 'grep -i CRON /var/log/syslog 2>/dev/null | tail -n 80' 2>/dev/null || true)"
    files_out="$(ssh -n $resolved 'find /var/www/vhosts -type f -mtime -1 2>/dev/null | head -n 50' 2>/dev/null || true)"
    hist_out="$(ssh -n $resolved 'tail -n 100 /home/exampleuser/.bash_history 2>/dev/null' 2>/dev/null || true)"

    for cmd in "$cron_cmd" "$files_cmd" "$hist_cmd"; do
      verdict="$(validator_check "$cmd" || true)"
      echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then
        run_command "$cmd"
      fi
    done

    echo
    echo "FOLLOW-UP ADVERSARIAL REVIEW:"
    echo "Guardrails:"
    echo "- max 3 hops"
    echo "- read-only only"
    echo "- no repeated evidence source"
    echo "- no same empty query twice"
    echo "- skeptic must propose the next source"
    echo "- judge must choose confirm, correct, or continue"
    echo "- stop when confidence is sufficient"
    echo

    echo "HOP 1 — CRON / SCHEDULER SIGNALS"
    echo "[ANALYST] Source: cron-related syslog entries from the last available window."
    if [ -z "$cron_out" ]; then
      echo "[ANALYST] No cron evidence was returned."
    else
      echo "[ANALYST] Cron-related evidence was returned."
    fi
    echo "[SKEPTIC] Syslog may not be the only scheduler trail. A different source is needed before concluding anything."
    echo "[JUDGE] Decision: continue."
    echo

    echo "HOP 2 — RECENT FILE MODIFICATIONS"
    echo "[ANALYST] Source: files under /srv/example modified in the last 24 hours."
    if [ -z "$files_out" ]; then
      echo "[ANALYST] No recent file modifications were returned."
    else
      echo "[ANALYST] Recent file modifications were returned."
    fi
    echo "[SKEPTIC] Modified files alone do not prove user action or shell activity. A different source is needed."
    echo "[JUDGE] Decision: continue."
    echo

    echo "HOP 3 — SHELL HISTORY"
    echo "[ANALYST] Source: /home/exampleuser/.bash_history tail."
    if [ -z "$hist_out" ]; then
      echo "[ANALYST] No shell history evidence was returned."
    else
      echo "[ANALYST] Shell history evidence was returned."
    fi
    echo "[SKEPTIC] Three independent follow-up sources have now been checked."
    echo "[JUDGE] Decision: confirm and stop."
    echo

    echo "FOLLOW-UP FINAL JUDGMENT:"
    if [ -z "$cron_out" ] && [ -z "$hist_out" ] && [ -n "$files_out" ]; then
      echo "I found recent file modifications, but no cron trail and no shell history from the checked source."
      echo
      echo "FOLLOW-UP CONFIDENCE:"
      echo "MEDIUM"
      echo
      echo "FOLLOW-UP NEXT PATH:"
      echo "Check app-specific logs named in the modified files list, ownership/timestamps, and other shell histories or service timers."
    elif [ -z "$cron_out" ] && [ -z "$files_out" ] && [ -z "$hist_out" ]; then
      echo "I did not get evidence from cron, recent file modifications, or shell history in these follow-up sources."
      echo
      echo "FOLLOW-UP CONFIDENCE:"
      echo "MEDIUM"
      echo
      echo "FOLLOW-UP NEXT PATH:"
      echo "Check service timers, rotated logs, alternate user histories, and application-specific logs."
    else
      echo "I found at least one follow-up signal that needs deeper review."
      echo
      echo "FOLLOW-UP CONFIDENCE:"
      echo "MEDIUM"
      echo
      echo "FOLLOW-UP NEXT PATH:"
      echo "Deepen the source that produced the signal before widening the search."
    fi
    echo

    return 0
  fi

  # deterministic diff (scoped path)
  if echo "$task_lc" | grep -qi "\bdiff\b" &&      echo "$task_lc" | grep -qiE "(^|[^[:alnum:]_])(prod|production|live|example-target)([^[:alnum:]_]|$)" &&      echo "$task_lc" | grep -qiE "(^|[^[:alnum:]_])(test|staging|dev|development)([^[:alnum:]_]|$)" &&      printf "%s\n" "$task" | grep -q " /"; then

    set -- $(printf "%s\n" "$task" | awk '{for(i=1;i<=NF;i++){if($i ~ /^\//){print $i}}}')
    prod_path="${1:-}"
    test_path="${2:-$1}"
    [ -z "$prod_path" ] && { echo "[validator] FAIL: scoped diff requires an absolute path"; echo; return 1; }

    prod_resolved="$(resolve_safe_target "example-target" 2>/dev/null || true)"
    test_resolved="$(resolve_safe_target "example-test" 2>/dev/null || true)"

    if [ -z "$prod_resolved" ] || [ "$prod_resolved" = "NOT_FOUND" ] || [ "$prod_resolved" = "UNSAFE" ] || [ "$prod_resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: prod target not configured safe"; echo; return 1
    fi
    if [ -z "$test_resolved" ] || [ "$test_resolved" = "NOT_FOUND" ] || [ "$test_resolved" = "UNSAFE" ] || [ "$test_resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: test target not configured safe"; echo; return 1
    fi

    echo "[exec-task] diff audit: prod:$prod_path vs test:$test_path (read-only)"
    echo
    if [ "$(same_host_warning_for_targets "$prod_resolved" "$test_resolved")" = "true" ]; then
      echo "[warning] prod and test resolve to the same host; comparison is environment-scoped, not machine-separated"
    fi

    prod_list="$(ssh -n $prod_resolved "find '$prod_path' -type f 2>/dev/null | sort" || true)"
    test_list="$(ssh -n $test_resolved "find '$test_path' -type f 2>/dev/null | sort" || true)"

    echo "[prod files]"
    printf "%s\n" "$prod_list" | head -n 50
    echo

    echo "[test files]"
    printf "%s\n" "$test_list" | head -n 50
    echo

    echo "[diff summary]"
    diff <(printf "%s\n" "$prod_list") <(printf "%s\n" "$test_list") | head -n 100 || true

    echo
    echo "DIFF NOTE:"
    echo "Scoped file comparison only. Use a narrower path for deeper inspection."
    echo

    return 0
  fi

  # deterministic diff path: prod vs test
  if echo "$task_lc" | grep -q "\bdiff\b" &&      echo "$task_lc" | grep -qE "(^|[^[:alnum:]_])(prod|production|live|example-target)([^[:alnum:]_]|$)" &&      echo "$task_lc" | grep -qE "(^|[^[:alnum:]_])(test|staging|dev|development)([^[:alnum:]_]|$)"; then

    prod_resolved="$(resolve_safe_target "example-target" 2>/dev/null || true)"
    test_resolved="$(resolve_safe_target "test" 2>/dev/null || true)"

    if [ -z "$prod_resolved" ] || [ "$prod_resolved" = "NOT_FOUND" ] || [ "$prod_resolved" = "UNSAFE" ] || [ "$prod_resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: prod target not configured safe"; echo; return 1
    fi
    if [ -z "$test_resolved" ] || [ "$test_resolved" = "NOT_FOUND" ] || [ "$test_resolved" = "UNSAFE" ] || [ "$test_resolved" = "NO_CONFIG" ]; then
      echo "[validator] FAIL: test target not configured safe"; echo; return 1
    fi

    echo "[exec-task] diff audit: prod vs test (read-only)"; echo
    if [ "$(same_host_warning_for_targets "$prod_resolved" "$test_resolved")" = "true" ]; then
      echo "[warning] prod and test resolve to the same host; comparison is environment-scoped, not machine-separated"
    fi

    prod_host_cmd="ssh -n $prod_resolved 'hostname && uptime && df -h'"
    test_host_cmd="ssh -n $test_resolved 'hostname && uptime && df -h'"
    prod_tree_cmd="ssh -n $prod_resolved 'find /var/www/vhosts -maxdepth 2 -type d 2>/dev/null | sort | head -n 200'"
    test_tree_cmd="ssh -n $test_resolved 'find /var/www/vhosts -maxdepth 2 -type d 2>/dev/null | sort | head -n 200'"

    for cmd in "$prod_host_cmd" "$test_host_cmd" "$prod_tree_cmd" "$test_tree_cmd"; do
      verdict="$(validator_check "$cmd" || true)"
      echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then
        run_command "$cmd"
      fi
    done

    echo
    echo "DIFF NOTE:"
    echo "This is a read-only structural comparison."
    echo "For deeper diffs, add a scoped file/path-specific task."
    echo

    return 0
  fi

  echo "[validator] FAIL: no deterministic execution path for this task yet"
  echo
  return 1
}

if [ "$QUIET_MODE" -eq 0 ]; then
  echo " //> NOMAD"
  echo " I am NOMAD MK-15c. You are the Creator."
  echo " Emergent Autonomous Infrastructure Orchestrator"
  echo " I execute deterministic reasoning under strict validation and controlled authority."
  echo " type 'exit' to quit"
  echo " commands: exec audit ssh-audit exec-task workflow decision run whoami models list recommend plan-install update discover bootstrap plan install approve deny memory status mode plan-install mempalace"
  echo
fi


mempalace_query() {
  local q="$1"
  local wing="$2"

  echo "[mempalace] query: $q"
  echo "[mempalace] wing: $wing"
  echo

  out="$(mempalace search "$q" --wing "$wing" 2>/dev/null)"

  if echo "$out" | grep -q "Results for"; then
    echo "$out"
    return 0
  fi

  return 1
}


mempalace_query() {
  local q="$1"
  local canon_out artist_out best_match combined_out body_out overlap_found
  local token

  echo "[mempalace] query: $q"
  echo

  canon_out="$(mempalace search "$q" --wing mempalace_canon 2>/dev/null)"
  artist_out="$(mempalace search "$q" --wing example-target 2>/dev/null)"

  combined_out="$(
    {
      printf '%s
' "$canon_out"
      printf '%s
' "$artist_out"
    }
  )"

  best_match="$(
    printf '%s
' "$combined_out" | awk '/Match:/ {print $2}' | sort -n | tail -1
  )"

  body_out="$(
    printf '%s
' "$combined_out" | grep -v '^  Results for: '
  )"

  overlap_found=1
  for token in $(printf '%s
' "$q" | tr '[:upper:]' '[:lower:]' | grep -oE '[a-z0-9._-]+' | awk 'length($0) >= 4'); do
    if printf '%s
' "$body_out" | tr '[:upper:]' '[:lower:]' | grep -Fqi -- "$token"; then
      overlap_found=0
      break
    fi
  done

  if [ -n "$best_match" ] && awk -v m="$best_match" 'BEGIN { exit !(m > -0.65) }' && [ "$overlap_found" -eq 0 ]; then
    printf '%s
' "$canon_out"
    echo
    printf '%s
' "$artist_out"
    return 0
  fi

  echo "No matching evidence found."
  return 1
}

translate_with_ollama() {
  local input="$1"
  local prompt raw first_line

  if ! command -v ollama >/dev/null 2>&1; then
    echo "$input"
    return
  fi

  prompt=$(cat <<EOF
You are a strict command translator for Nomad.

Return exactly one line only.

Allowed outputs:
- /audit
- /ssh-audit example-target
- /ssh-audit example-test
- /exec-task investigate example-target last night logs
- /exec-task investigate example-target followup 24h
- /exec-task diff prod test
- PASS_THROUGH

Rules:
- Do not explain anything.
- Do not add punctuation before or after the command.
- Do not invent hosts, domains, usernames, IPs, or file paths.
- Do not output any command except one from the allowed outputs above.
- If the request is unclear, lookup-oriented, conversational, or does not map exactly to one allowed output, return PASS_THROUGH.

User input:
$input
EOF
)

  raw="$(printf "%s" "$prompt" | ollama run mistral 2>/dev/null || true)"
  first_line="$(printf "%s
" "$raw" | sed -n '1p' | tr -d '
')"

  case "$first_line" in
    "/audit"|"/ssh-audit example-target"|"/ssh-audit example-test"|"/exec-task investigate example-target last night logs"|"/exec-task investigate example-target followup 24h"|"/exec-task diff prod test")
      echo "$first_line"
      return
      ;;
    *)
      echo "$input"
      return
      ;;
  esac
}

identity_query() {
  local task="$1"
  local lower
  lower="$(normalize_phrase "$task")"

  case "$lower" in
    "who are you"|"what are you"|"identify yourself"|"what is this"|"what is normad"|"nomad are you there"|"are you there"|"hello"|"hi")
      printf '%s\n' "__IDENTITY__"
      return 0
      ;;
  esac

  return 1
}

interactive_conversation_response() {
  local task="$1"
  local lower
  lower="$(normalize_phrase "$task")"

  case "$lower" in
    "status")
      nomad_voice_conversational_reply status
      echo 'The safest next step is to inspect memory status or models recommend.'
      return 0
      ;;
    "help"|"what can you do here"|"what can you do"|"show commands")
      nomad_voice_conversational_reply help
      echo 'Try: models recommend, bootstrap plan, memory status, run show <run_id>, approve <run_id>.'
      return 0
      ;;
    "what models fit this machine"|"recommend a model for reasoning"|"recommend a model for coding"|"help me set this up for coding")
      nomad_voice_conversational_reply next_step
      echo 'The safest next step is models recommend.'
      if [ "$INTERACTIVE_SESSION" -eq 1 ]; then
        model_catalog_recommend
        nomad_voice_operator_summary model_recommendation
      fi
      return 0
      ;;
    "show me the next safe step")
      nomad_voice_conversational_reply next_step
      echo 'Usually bootstrap plan or models recommend, depending on whether you are setting up the system or choosing a model.'
      return 0
      ;;
    "explain what just happened")
      nomad_voice_conversational_reply status
      echo 'If you point me at a run, I can explain it. Try run show <run_id>.'
      return 0
      ;;
    "create a bootstrap plan")
      nomad_voice_conversational_reply next_step
      if [ "$INTERACTIVE_SESSION" -eq 1 ]; then
        bootstrap_plan
        nomad_voice_operator_summary bootstrap_created
      fi
      return 0
      ;;
    "what memory mode am i using"|"what memory mode am i using?")
      memory_mode
      return 0
      ;;
  esac

  return 1
}

interactive_conversation_probe() {
  local task="$1"
  local lower
  lower="$(normalize_phrase "$task")"

  case "$lower" in
    "status"|"help"|"what can you do here"|"what can you do"|"show commands"|"what models fit this machine"|"recommend a model for reasoning"|"recommend a model for coding"|"help me set this up for coding"|"show me the next safe step"|"explain what just happened"|"create a bootstrap plan"|"what memory mode am i using"|"what memory mode am i using?"|"who are you"|"what are you"|"identify yourself"|"what is this"|"what is normad"|"nomad are you there"|"are you there"|"hello"|"hi")
      return 0
      ;;
  esac

  return 1
}

normalize_command_input() {
  local task="$1"
  local lower
  lower="$(printf "%s" "$task" | tr "[:upper:]" "[:lower:]")"

  case "$lower" in
    exec\ *|audit|ssh-audit\ *|exec-task\ *|workflow\ *|decision\ *|run\ *|whoami|models\ *|bootstrap\ *|plan\ *|approve\ *|deny\ *|memory\ *|discover-new-compatible-models\ *)
      if echo "$task" | grep -q '^/'; then
        printf '%s\n' "$task"
        return 0
      fi
      ;;
  esac

  case "$lower" in
    exec\ *) printf '/exec %s\n' "${task#exec }" ; return 0 ;;
    audit) printf '%s\n' '/audit' ; return 0 ;;
    ssh-audit\ *) printf '/ssh-audit %s\n' "${task#ssh-audit }" ; return 0 ;;
    exec-task\ *) printf '/exec-task %s\n' "${task#exec-task }" ; return 0 ;;
    workflow\ *) printf '/workflow %s\n' "${task#workflow }" ; return 0 ;;
    decision\ *) printf '/decision %s\n' "${task#decision }" ; return 0 ;;
    run\ *) printf '/run %s\n' "${task#run }" ; return 0 ;;
    whoami) printf '%s\n' '/whoami' ; return 0 ;;
    models\ *) printf '/models %s\n' "${task#models }" ; return 0 ;;
    bootstrap\ *) printf '/bootstrap %s\n' "${task#bootstrap }" ; return 0 ;;
    plan\ *) printf '/plan %s\n' "${task#plan }" ; return 0 ;;
    approve\ *) printf '/approve %s\n' "${task#approve }" ; return 0 ;;
    deny\ *) printf '/deny %s\n' "${task#deny }" ; return 0 ;;
    help) printf '%s\n' '/help' ; return 0 ;;
    help\ *) printf '/help %s\n' "${task#help }" ; return 0 ;;
    discover-new-compatible-models) printf '%s\n' '/models discover-new-compatible-models' ; return 0 ;;
    discover-new-compatible-models\ *) printf '/models discover-new-compatible-models %s\n' "${task#discover-new-compatible-models }" ; return 0 ;;
    memory) printf '%s\n' '/memory status' ; return 0 ;;
    memory\ plan-install\ mempalace) printf '%s\n' '/memory plan-install mempalace' ; return 0 ;;
    memory\ plan-install\ mempalace\ *) printf '/memory plan-install mempalace %s\n' "${task#memory plan-install mempalace }" ; return 0 ;;
    memory\ *) printf '/memory %s\n' "${task#memory }" ; return 0 ;;
  esac

  printf '%s\n' "$task"
}

route_nl_task() {
  local task="$1"
  local lower
  lower="$(printf "%s" "$task" | tr "[:upper:]" "[:lower:]")"

  if echo "$lower" | grep -q '^/exec-task '; then
    echo "$task"
    return 0
  fi

  if echo "$lower" | grep -q '^/workflow '; then
    echo "$task"
    return 0
  fi

  if echo "$lower" | grep -q '^/run '; then
    echo "$task"
    return 0
  fi

  if echo "$lower" | grep -q '^/workflow list$'; then
    echo "/workflow list"
    return 0
  fi

  if echo "$lower" | grep -q '^/run last$'; then
    echo "/run last"
    return 0
  fi

  if echo "$lower" | grep -q '^/decision explain '; then
    echo "$task"
    return 0
  fi

  if identity_query "$task"; then
    return 0
  fi

  # production / live / prod
  if echo "$lower" | grep -qiE '^run production baseline$'; then
    echo "/workflow run workflow_prod_baseline"
    return 0
  fi
  if echo "$lower" | grep -qiE '^investigate production last night$'; then
    echo "/workflow run workflow_prod_investigate_last_night"
    return 0
  fi
  if echo "$lower" | grep -qiE '^compare prod and test webroot$'; then
    echo "/workflow run workflow_test_vs_prod_webroot"
    return 0
  fi
  if echo "$lower" | grep -qiE '^run production health decision$'; then
    echo "/workflow run-smart workflow_prod_health_decision"
    return 0
  fi
  if echo "$lower" | grep -qiE '^investigate or compare prod and test$'; then
    echo "/workflow run-smart workflow_investigate_or_compare"
    return 0
  fi
  if echo "$lower" | grep -qiE '^smart run production baseline$'; then
    echo "/workflow run-smart workflow_prod_baseline"
    return 0
  fi
  if echo "$lower" | grep -qiE '^explain decision flow for production health$'; then
    echo "/decision explain workflow_prod_health_decision"
    return 0
  fi

  if echo "$lower" | grep -qiE "(^|[^[:alnum:]_])(prod|production|live)([^[:alnum:]_]|$)"; then
    if echo "$lower" | grep -qiE "what happened|last night|early morning|around [0-9]|logs?"; then
      echo "/exec-task investigate example-target last night logs"
      return 0
    fi
    if echo "$lower" | grep -qiE "ssh|audit|uptime|disk|df|hostname|php|apache|nginx|server"; then
      echo "/ssh-audit example-target"
      return 0
    fi
  fi

  # test / staging / dev / development
  if echo "$lower" | grep -qiE "(^|[^[:alnum:]_])(test|staging|dev|development)([^[:alnum:]_]|$)"; then
    if echo "$lower" | grep -qiE "ssh|audit|uptime|disk|df|hostname|php|apache|nginx|server|logs?"; then
      echo "/ssh-audit example-test"
      return 0
    fi
  fi

  # follow-up deterministic routing
  if echo "$lower" | grep -qiE "cron|app|logs|file modification|file changes|shell history|history|past 24|24 hours|return and check"; then
    echo "/exec-task investigate example-target followup 24h"
    return 0
  fi

  # diff routing
  if echo "$lower" | grep -qi "\bdiff\b" &&      echo "$lower" | grep -qiE "(^|[^[:alnum:]_])(prod|production|live|example-target)([^[:alnum:]_]|$)" &&      echo "$lower" | grep -qiE "(^|[^[:alnum:]_])(test|staging|dev|development)([^[:alnum:]_]|$)"; then
    echo "/exec-task diff prod test"
    return 0
  fi

  echo "$task"
}


dispatch_task() {
  local TASK="$1"
  local normalized_command=0
  local normalized_task=""
  local lower_task=""
  local help_topic=""
  local namespace=""
  local memory_args=""
  local memory_namespace=""
  local memory_key=""
  local memory_query=""
  local RAW_TARGET=""
  local RESOLVED=""
  local CMD=""
  local verdict=""

  if [ -z "${TASK// }" ]; then
    return 0
  fi
  [ "$TASK" = "exit" ] && return 0

  if identity_query "$TASK"; then
    respond_identity
    return 0
  fi

  if [ "$INTERACTIVE_SESSION" -eq 1 ] && interactive_conversation_response "$TASK"; then
    return 0
  fi

  normalized_task="$(normalize_command_input "$TASK")"
  if [ "$normalized_task" != "$TASK" ] && echo "$normalized_task" | grep -q '^/'; then
    normalized_command=1
    TASK="$normalized_task"
  fi

  if [ "$normalized_command" -eq 0 ]; then
    if echo "$TASK" | grep -q '^/'; then
      TASK="$TASK"
    else
      TASK="$(translate_with_ollama "$TASK")"
      if ! echo "$TASK" | grep -q '^/'; then
        lower_task="$(printf "%s" "$TASK" | tr "[:upper:]" "[:lower:]")"
        if echo "$lower_task" | grep -q "portal architecture"; then
          TASK="class-portal-router.php portal routes"
        elif echo "$lower_task" | grep -q "^system a$"; then
          TASK="System A"
        elif echo "$lower_task" | grep -q "^system b$"; then
          TASK="System B"
        elif echo "$lower_task" | grep -q "^my stack$"; then
          TASK="example-target stack"
        fi
      fi
      TASK="$(route_nl_task "$TASK")"
    fi
  fi

  if [ "$TASK" = "__IDENTITY__" ]; then
    respond_identity
    return 0
  fi

  # Memory-first enforcement (non-command input only, after NL routing)
  if [ "$INTERACTIVE_SESSION" -eq 1 ] && interactive_conversation_probe "$TASK"; then
    return 0
  fi

  if [ "$normalized_command" -eq 0 ] && ! echo "$TASK" | grep -q '^/'; then
    if mempalace_query "$TASK"; then
      return 0
    fi
  fi

  if [ -z "${TASK// }" ]; then
    return 0
  fi
  [ "$TASK" = "exit" ] && return 0

  case "$TASK" in
    /whoami)
      respond_identity
      return 0
      ;;

    /help)
      echo "commands: exec audit ssh-audit exec-task workflow decision run whoami models list recommend plan-install update discover bootstrap plan install approve deny memory status mode plan-install mempalace"
      echo "compatibility aliases: slash-prefixed forms remain supported"
      return 0
      ;;

    /help\ *)
      help_topic="${TASK#"/help "}"
      case "$help_topic" in
        models)
          echo "models list"
          echo "models recommend"
          echo "models discover"
          echo "models plan-install <model_id>"
          echo "models update <model_id>"
          ;;
        memory)
          echo "memory status"
          echo "memory mode"
          echo "memory plan-install mempalace"
          echo "memory backend-test"
          ;;
        *)
          echo "commands: exec audit ssh-audit exec-task workflow decision run whoami models bootstrap plan approve deny memory"
          ;;
      esac
      return 0
      ;;

    /models\ list)
      model_catalog_list
      return 0
      ;;

    /models\ recommend)
      model_catalog_recommend
      return 0
      ;;

    /models\ update)
      model_update
      return 0
      ;;

    /models\ update\ *)
      model_update_plan "${TASK#"/models update "}"
      return 0
      ;;

    /models\ plan-install\ *)
      model_plan_install "${TASK#"/models plan-install "}"
      return 0
      ;;

    /models\ install\ *)
      install_model_if_approved "${TASK#"/models install "}"
      return 0
      ;;

    /models\ discover-new-compatible-models)
      discover_new_compatible_models
      return 0
      ;;

    /models\ discover)
      discover_new_compatible_models
      return 0
      ;;

    /bootstrap\ plan)
      bootstrap_plan
      return 0
      ;;

    /bootstrap\ install)
      install_bootstrap_if_approved "${TASK#"/bootstrap install "}"
      return 0
      ;;

    /run\ resume\ *)
      run_resume "${TASK#"/run resume "}"
      return 0
      ;;

    /run\ show\ *)
      if plan_record_exists "${TASK#"/run show "}"; then
        run_record_show "${TASK#"/run show "}"
      else
        workflow_show_run "${TASK#"/run show "}"
      fi
      return 0
      ;;

    /plan\ run\ *)
      plan_run "${TASK#"/plan run "}"
      return 0
      ;;

    /approve\ *)
      approve_run "${TASK#"/approve "}"
      return 0
      ;;

    /deny\ *)
      deny_run "${TASK#"/deny "}"
      return 0
      ;;

    /memory\ status)
      memory_status
      return 0
      ;;

    /memory\ mode)
      memory_mode
      return 0
      ;;

    /memory\ list\ *)
      namespace="${TASK#"/memory list "}"
      memory_list_namespace "$(memory_namespace_for_command "$namespace")"
      return 0
      ;;

    /memory\ show\ *)
      memory_args="${TASK#"/memory show "}"
      memory_namespace="${memory_args%% *}"
      memory_key="${memory_args#* }"
      if [ "$memory_namespace" = "$memory_key" ]; then
        echo "unknown record"
        return 0
      fi
      memory_show_record "$(memory_namespace_for_command "$memory_namespace")" "$memory_key"
      return 0
      ;;

    /memory\ search\ *)
      memory_args="${TASK#"/memory search "}"
      memory_namespace="${memory_args%% *}"
      memory_query="${memory_args#* }"
      if [ "$memory_namespace" = "$memory_query" ]; then
        echo "unknown query"
        return 0
      fi
      memory_search "$(memory_namespace_for_command "$memory_namespace")" "$memory_query"
      return 0
      ;;

    /memory\ reflections)
      memory_refresh_reflections
      memory_get_reflections
      return 0
      ;;

    /memory\ backend-test)
      memory_backend_test
      return 0
      ;;

    /memory\ plan-install\ mempalace)
      memory_plan_install_mempalace
      return 0
      ;;

    /memory\ plan-install\ mempalace\ *)
      memory_plan_install_mempalace
      return 0
      ;;

    /workflow\ list)
      workflow_list
      return 0
      ;;

    /workflow\ show\ *)
      workflow_show "${TASK#"/workflow show "}"
      return 0
      ;;

    /workflow\ run\ *)
      workflow_run "${TASK#"/workflow run "}"
      return 0
      ;;

    /workflow\ run-smart\ *)
      workflow_smart_run "${TASK#"/workflow run-smart "}"
      return 0
      ;;

    /run\ last)
      run_last_workflow
      return 0
      ;;

    /run\ resume\ *)
      run_resume "${TASK#"/run resume "}"
      return 0
      ;;

    /run\ show\ *)
      if plan_record_exists "${TASK#"/run show "}"; then
        run_record_show "${TASK#"/run show "}"
      else
        workflow_show_run "${TASK#"/run show "}"
      fi
      return 0
      ;;

    /decision\ explain\ *)
      workflow_decision_explain "${TASK#"/decision explain "}"
      return 0
      ;;

    /exec\ *)
      CMD="${TASK#"/exec "}"
      verdict="$(validator_check "$CMD" || true)"; echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then run_command "$CMD"; fi
      return 0
      ;;

    /audit)
      echo "[audit] basic system audit"; echo
      for c in "whoami" "hostname" "uptime" "df -h" "free -h"; do
        verdict="$(validator_check "$c" || true)"; echo "[validator] $verdict"
        if echo "$verdict" | grep -q '^PASS:'; then run_command "$c"; fi
      done
      return 0
      ;;

    /ssh-audit\ *)
      RAW_TARGET="${TASK#"/ssh-audit "}"
      RESOLVED="$(resolve_safe_target "$RAW_TARGET" 2>/dev/null || true)"
      if [ -z "$RESOLVED" ] || [ "$RESOLVED" = "NOT_FOUND" ] || [ "$RESOLVED" = "UNSAFE" ] || [ "$RESOLVED" = "NO_CONFIG" ]; then
        echo "[validator] FAIL: target not configured safe"
        return 0
      fi
      CMD="ssh -n $RESOLVED 'hostname && uptime && df -h'"
      verdict="$(validator_check "$CMD" || true)"; echo "[validator] $verdict"
      if echo "$verdict" | grep -q '^PASS:'; then run_command "$CMD"; fi
      return 0
      ;;

    /exec-task\ *)
      exec_task "${TASK#"/exec-task "}"
      return 0
      ;;

    /*)
      echo "unknown command"
      return 0
      ;;
  esac

  return 0
}

if [ "$#" -gt 0 ]; then
  dispatch_task "$*"
  exit $?
fi

if [ ! -t 0 ]; then
  while IFS= read -r TASK || [ -n "$TASK" ]; do
    [ -z "${TASK// }" ] && continue
    dispatch_task "$TASK"
  done
  exit 0
fi

while true; do
  printf "//> "
  read -r TASK || break
  [ "$TASK" = "exit" ] && break
  dispatch_task "$TASK"
done

translate_query() {
  local q="$1"

  case "$(printf "%s" "$q" | tr "[:upper:]" "[:lower:]")" in
    "who are you"|"what are you"|"identify yourself"|"what is this"|"what is normad")
      echo "__IDENTITY__"
      return
      ;;
  esac

  if echo "$q" | grep -qi "my stack"; then
    echo "example-target stack"
    return
  fi

  if echo "$q" | grep -qi "what did we audit"; then
    echo "audit"
    return
  fi

  echo "$q"
}
